// room script.0file

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

function room_Load()
{
  FadeIn(1);
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

function room_AfterFadeIn()
{
  // Intro
  Wait(20);
  Display("Uneasy dreams fade as you come to your senses. You are lying in an unfamiliar place, lit only by a sickly green glow that seeps from the stone around you.");
  Display("Your weapons and supplies are gone. Whatever brought you here has left you with nothing but your clothes and the armor you were wearing. The situation raises several troubling questions:");
  Display("Where are you?\nHow did you arrive here?\nWhat kind of place is this?\nAnd how are you going to survive long enough to escape?");

  // Force pointer mode
  Mouse.UseModeGraphic(eModeLookat);
  Mouse.Mode = eModeLookat;
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - -

// Room
function hRoom_Look(Hotspot *theHotspot, CursorMode mode)
{
  Display("You stand in a cavern, its walls faintly glow with patches of phosphorescent growth. Jagged stones rise from the floor in twisted formations, resembling the bones of some colossal creature long entombed here. Scattered throughout the chamber, human figures are fused with the rock itself, half-swallowed by stone as though the cave is still claiming them.");
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Altar
function hAltar_Look(Hotspot *theHotspot, CursorMode mode)
{
  Display("This seems to be a ritual altar, shaped with deliberate intent rather than chance. Torch-holders stand at either side of an offering bowl, its interior stained by countless past rites. The air around it feels heavy, as though the stone itself remembers what was done here.");
}

function hAltar_Interact(Hotspot *theHotspot, CursorMode mode)
{
  WalkToInteraction(193, 150, eDirectionRight, WAIT_DEFAULT);
  Display("The altar radiates an unnatural warmth, but the feeling it leaves behind is anything but comforting.");
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Torch - Right - Takable
function oTorchRight_Look(Object *theObject, CursorMode mode)
{
  Display("It looks like a torch, though it bears no trace of anything that should allow it to burn.");
}

function oTorchRight_UseInv(Object *theObject, CursorMode mode)
{
  WalkToInteraction(212, 158, eDirectionRight, WAIT_DEFAULT);
  if ((player.ActiveInventory == iFlint || player.ActiveInventory == iDagger) && oTorchRight.Graphic != 51){
    if (player.HasInventory(iDagger) && player.HasInventory(iFlint)){
      Display("You strike flint to dagger. A shower of sparks erupts, and the torch springs to life in a bright turquoise flame that no ordinary fire should burn.");
      if (oTorchLeft.Graphic != 50){ // If left torch is not yet lit
        oTorchLeft.Graphic = 68; // Make left torch illuminated
      }
      oTorchRight.Graphic = 51; // Make right torch lit
      oLightMain.Visible = true; // Turn on main light
    }
    else if (!player.HasInventory(iDagger)){
      Display("You have no blade to strike the flint against.");
    }
    else if (!player.HasInventory(iFlint)){
      Display("You try to coax a spark from the dagger, but without the right kind of stone, the attempt is futile.");
    }
  }
  else if (oTorchRight.Graphic == 51){
    if (player.ActiveInventory == iFlint){
      Display("The torch is already lit.");
    }
  }
}

function oTorchRight_Interact(Object *theObject, CursorMode mode)
{
  WalkToInteraction(212, 158, eDirectionRight, WAIT_DEFAULT);
  if (oTorchLeft.Graphic != 50){
    oLightMain.Visible = false;
  }
  if (oTorchLeft.Graphic != 50){ // If left torch is not yet lit
    oTorchLeft.Graphic = 49; // Return left torch to not illuminated
  }
  oTorchRight.Visible = false; // Get rid of the right torch
  Display("You remove the torch from it's holder and carry it with you.");
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Torch - Left
function oTorchLeft_Look(Object *theObject, CursorMode mode)
{
  Overlay.CreateGraphical(130, 189, 52);
  Display("It looks like a torch, though it bears no trace of anything that should allow it to burn.");
}

function oTorchLeft_Interact(Object *theObject, CursorMode mode)
{
  WalkToInteraction(193, 150, eDirectionRight, WAIT_DEFAULT);
  Display("The torch is stuck in it's holder.");
}

function oTorchLeft_UseInv(Object *theObject, CursorMode mode)
{
  WalkToInteraction(193, 150, eDirectionRight, WAIT_DEFAULT);
  if ((player.ActiveInventory == iFlint || player.ActiveInventory == iDagger)  && oTorchLeft.Graphic != 50){
    if (player.HasInventory(iDagger) && player.HasInventory(iFlint)){
      Display("You strike flint to dagger. A shower of sparks erupts, and the torch springs to life in a bright turquoise flame that no ordinary fire should burn.");
      oTorchLeft.Graphic = 50;
      oLightMain.Visible = true;
    }
    else if (!player.HasInventory(iDagger)){
      Display("You have no blade to strike the flint against.");
    }
    else if (!player.HasInventory(iFlint)){
      Display("You try to coax a spark from the dagger, but without the right kind of stone, the attempt is futile.");
    }
  }
  else if (oTorchLeft.Graphic == 50){
    if (player.ActiveInventory == iFlint){
      Display("The torch is already lit.");
    }
  }
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Door
function oDoor_Look(Object *theObject, CursorMode mode)
{
  Display("The opening resembles a living passageway, its stone edges drawn inward as though clenched. It looks less like a doorway and more like something deciding whether to let you pass.");
}
function oDoor_Interact(Object *theObject, CursorMode mode)
{
  WalkToInteraction(148, 114, eDirectionUp, WAIT_DEFAULT);
  Display("The opening does not respond, as though the cave itself has decided against letting you pass.");
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Corpse 1 - Left Soldier
function hCorpse1_Look(Hotspot *theHotspot, CursorMode mode)
{
  Display("A fallen warrior lies here, his bones bound in rusted armor and a dented helm, half-buried in stone.");
}

function hCorpse1_Interact(Hotspot *theHotspot, CursorMode mode)
{
  WalkToInteraction(119, 163, eDirectionLeft, WAIT_DEFAULT);

  if (!player.HasInventory(iDagger)){
    Display("You search the corpse of the warrior recovering a dagger and a small clutch of coins, each bearing the mark of a kopek.");
    AddGold(3);
    player.AddInventory(iDagger);
  }
  else {
    Display("You search the corpse again, but there is nothing else of value to be found.");
  }
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Corpse 2 - Centre of room
function hCorpse2_Look(Hotspot *theHotspot, CursorMode mode)
{
  Display("The remains are little more than a suggestion of a person, half-lost to dust and shadow.");
}

function hCorpse2_Interact(Hotspot *theHotspot, CursorMode mode)
{
  WalkToInteraction(135, 166, eDirectionUp, WAIT_DEFAULT);
  Display("There is no reason to handle the bones, and nothing visible to search through.");
}


// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Corpse 3 - Hanging off floor
function hCorpse3_Look(Hotspot *theHotspot, CursorMode mode)
{
  Display("The deteriorated corpse has grown partway into the cave floor.");
}

function hCorpse3_Interact(Hotspot *theHotspot, CursorMode mode)
{
  WalkToInteraction(175, 175, eDirectionDown, WAIT_DEFAULT);
  Display("There is no reason to handle the bones of this deteriorated corpse.");
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Flint
function oFlint_Look(Object *theObject, CursorMode mode)
{
  Display("You keenly see a piece of hard-grey rock on the cavern floor.");
}

function oFlint_Interact(Object *theObject, CursorMode mode)
{
  WalkToInteraction(150, 163, eDirectionUp, WAIT_DEFAULT);
  Display("You kneel down and pick up the flint rock.");
  oFlint.Visible = false;
  player.AddInventory(iFlint);
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Pouch
function oCoinPouch_Look(Object *theObject, CursorMode mode)
{
  Display("A small coin purse lies wedged beside the skeleton, left behind where the remains hang precariously from the ledge.");
}

function oCoinPouch_Interact(Object *theObject, CursorMode mode)
{
  WalkToInteraction(175, 175, eDirectionDown, WAIT_DEFAULT);
  Display("You retrieve the coin purse from beside the skeleton, careful not to disturb the remains any more than necessary. Opening the coin purse, you find four kopeks inside.");
  AddGold(4);
  oCoinPouch.Visible = false;
}