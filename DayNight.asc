// ==============================
// DayNight.asc (module script)
// ==============================
//
// Design goals:
// - No forward declarations (AGS doesn't like them). Order matters.
// - No ternary operator (AGS parsing can be strict).
// - No macro math; use const ints.
// - One place to define times-of-day (slice boundaries).
// - One place to define which rooms swap backgrounds.

// ------------------------------------------
// Define times of day (single source of truth)
// ------------------------------------------

// Slice boundaries (minutes since midnight)
const int SLICE_DAWN_START    = 300;   // 05:00
const int SLICE_DAY_START     = 420;   // 08:00
const int SLICE_LATEAFT_START = 960;   // 15:00
const int SLICE_DUSK_START    = 1080;  // 18:00
const int SLICE_NIGHT_START   = 1140;  // 20:00

const int MINUTES_PER_DAY     = 1440;

// 24 in-game hours = 15 real minutes (96x realtime)
// Default AGS speed is typically 40 loops/sec.
// 2.4 game-seconds per loop = 24 tenths per loop.
const int TIME_TENTHS_PER_LOOP = 24;

// ------------------------------------------
// Define which rooms need DayNight background swapping
// ------------------------------------------

bool Time_RoomUsesBackgroundDayNight(int _room)
{
  // Return true for rooms that have the 5 background frames and should swap them.
  // Return false for rooms that should NOT swap backgrounds (tint-only or do nothing).
  //
  // Keep this as the single source of truth.
  // Add rooms as you build them.

  // Example list (yours, keep/edit):
  if (_room == 6) return true;
  if (_room == 7) return true;

  // Default: no background swapping
  return false;
}

// ------------------------------------------
// Globals (exported)
// ------------------------------------------

bool gClockRunning = false;

int gTimeDay = 1;
int gTimeHour = 8;
int gTimeMinute = 0;
int gTimeSecond = 0;

// Mode used by Time_ApplyVisuals():
// true  = swap backgrounds
// false = ambient tint (actors/objects) only
bool gBackgroundDayNight = false;

export gClockRunning;
export gTimeDay;
export gTimeHour;
export gTimeMinute;
export gTimeSecond;
export gBackgroundDayNight;

// ------------------------------------------
// Internals
// ------------------------------------------

int _timeTenthsAccum = 0;

// ------------------------------------------
// Helpers / Queries (define early; used later)
// ------------------------------------------

int Time_GetTotalMinutes()
{
  return (gTimeHour * 60) + gTimeMinute;
}

eDaySlice5 Time_GetDaySlice5()
{
  int _m = Time_GetTotalMinutes();

  // Night crosses midnight (20:00 -> 05:00)
  if (_m >= SLICE_NIGHT_START || _m < SLICE_DAWN_START) return eSlice_Night;

  if (_m >= SLICE_DUSK_START) return eSlice_Dusk;
  if (_m >= SLICE_LATEAFT_START) return eSlice_LateAfternoon;
  if (_m >= SLICE_DAY_START) return eSlice_Day;

  return eSlice_Dawn;
}

bool Time_IsDaySlice5(eDaySlice5 _slice)
{
  return (Time_GetDaySlice5() == _slice);
}

int Time_GetBackgroundFrameForSlice(eDaySlice5 _slice)
{
  // Enum value == background frame index by design.
  return _slice;
}

// ------------------------------------------
// Visual functions (called by tick/update)
// ------------------------------------------

void Time_ApplyRoomBackgroundForTime()
{
  // Only rooms with >1 background can swap.
  if (Room.BackgroundCount <= 1) return;

  int _frame = Time_GetBackgroundFrameForSlice(Time_GetDaySlice5());

  // Safety fallback if this room has fewer than 5 frames.
  if (_frame >= Room.BackgroundCount) _frame = 0;

  SetBackgroundFrame(_frame);
}

void Time_RemoveAmbientTint()
{
  // Neutral / no tint
  SetAmbientTint(0, 0, 0, 0, 100);
}

void Time_ApplyAmbientTint()
{
  // Tints characters/objects (not the painted background).
  // SetAmbientTint(red, green, blue, saturation, luminance)

  eDaySlice5 _s = Time_GetDaySlice5();

  if (_s == eSlice_Day) Time_RemoveAmbientTint();
  else if (_s == eSlice_LateAfternoon) SetAmbientTint(255, 210, 125, 22, 95);
  else if (_s == eSlice_Dusk) SetAmbientTint(255, 115, 75, 48, 82);
  else if (_s == eSlice_Night) SetAmbientTint(70, 110, 255, 42, 58);
  else SetAmbientTint(255, 175, 95, 34, 92); // Dawn
}

void Time_ApplyVisuals()
{
  // Apply visuals using current mode.
  // true  => swap backgrounds
  // false => ambient tint
  if (gBackgroundDayNight) Time_ApplyRoomBackgroundForTime();
  else Time_ApplyAmbientTint();
}

void Time_ApplyVisualsForRoom(int _room)
{
  // Central entry point on room-enter.
  // Sets the correct mode for this room, then applies visuals.
  gBackgroundDayNight = Time_RoomUsesBackgroundDayNight(_room);
  Time_ApplyVisuals();
}

// ------------------------------------------
// Normalize + tick helpers (define after visuals)
// because they call Time_ApplyVisuals()
// ------------------------------------------

void _Time_NormalizeForward()
{
  while (gTimeSecond >= 60) { gTimeSecond -= 60; gTimeMinute++; }
  while (gTimeMinute >= 60) { gTimeMinute -= 60; gTimeHour++; }
  while (gTimeHour >= 24)   { gTimeHour -= 24;   gTimeDay++;  }
}

void _Time_NormalizeBackward()
{
  while (gTimeSecond < 0) { gTimeSecond += 60; gTimeMinute--; }
  while (gTimeMinute < 0) { gTimeMinute += 60; gTimeHour--; }
  while (gTimeHour < 0)   { gTimeHour += 24;   gTimeDay--; }
  if (gTimeDay < 1) gTimeDay = 1;
}

void _Time_AddGameSeconds(int _seconds)
{
  gTimeSecond += _seconds;

  _Time_NormalizeForward();
  _Time_NormalizeBackward();

  // Non-blocking only
  Time_ApplyVisuals();
}

// ------------------------------------------
// Public clock API (define last)
// ------------------------------------------

void Time_Init(int _startDay, int _startHour, int _startMinute, int _startSecond)
{
  gTimeDay = _startDay;
  gTimeHour = _startHour;
  gTimeMinute = _startMinute;
  gTimeSecond = _startSecond;

  _timeTenthsAccum = 0;

  _Time_NormalizeForward();
  _Time_NormalizeBackward();

  Time_ApplyVisuals();
}

void Time_Update()
{
  if (!gClockRunning) return;

  _timeTenthsAccum += TIME_TENTHS_PER_LOOP;

  while (_timeTenthsAccum >= 10)
  {
    _timeTenthsAccum -= 10;
    _Time_AddGameSeconds(1);
  }
}

void Time_AdvanceMinutes(int _minutes)
{
  _Time_AddGameSeconds(_minutes * 60);
}

void Time_AdvanceHours(int _hours)
{
  _Time_AddGameSeconds(_hours * 3600);
}

void Time_AdvanceUntilDusk()
{
  int _current = Time_GetTotalMinutes();
  int _target = SLICE_DUSK_START; // 18:00
  int _delta = 0;

  if (_current < _target) _delta = _target - _current;
  else _delta = (MINUTES_PER_DAY - _current) + _target;

  if (gTimeSecond > 0) _delta += 1;

  Time_AdvanceMinutes(_delta);
}

void Time_AdvanceUntilMorning()
{
  // "Morning" here means Day start at 08:00 to match your Day background frame.
  // If you want Dawn start (05:00), change _target to SLICE_DAWN_START.
  int _current = Time_GetTotalMinutes();
  int _target = SLICE_DAY_START; // 08:00
  int _delta = 0;

  if (_current < _target) _delta = _target - _current;
  else _delta = (MINUTES_PER_DAY - _current) + _target;

  if (gTimeSecond > 0) _delta += 1;

  Time_AdvanceMinutes(_delta);
}

// ------------------------------------------
// UI helpers (strings)
// ------------------------------------------

String Time_GetClockString()
{
  return String.Format("%02d:%02d", gTimeHour, gTimeMinute);
}

// Returns a flavorful time-of-day label for the UI.
String Time_GetClockPeriodString()
{
  int _m = Time_GetTotalMinutes();

  if (_m >= 240 && _m < 300)   return "Before Sunrise";       // 04:00-04:59
  if (_m >= 300 && _m < 360)   return "Dawn";                 // 05:00-05:59
  if (_m >= 360 && _m < 420)   return "Sunrise";              // 06:00-06:59
  if (_m >= 420 && _m < 540)   return "Morning";              // 07:00-08:59
  if (_m >= 540 && _m < 660)   return "Mid-Morning";          // 09:00-10:59
  if (_m >= 660 && _m < 780)   return "Midday";               // 11:00-12:59
  if (_m >= 780 && _m < 960)   return "Afternoon";            // 13:00-15:59
  if (_m >= 960 && _m < 1080)  return "Late Afternoon";       // 16:00-17:59
  if (_m >= 1080 && _m < 1140) return "Early Evening";        // 18:00-18:59
  if (_m >= 1140 && _m < 1320) return "Evening";              // 19:00-21:59
  if (_m >= 1320 && _m < 1440) return "Before Midnight";      // 22:00-23:59
  if (_m >= 0 && _m < 120)     return "Middle of the Night";  // 00:00-01:59

  return "Early Hours";                                       // 02:00-03:59
}

String Time_GetClockPeriodAndTimeString()
{
  return String.Format("%s  %02d:%02d", Time_GetClockPeriodString(), gTimeHour, gTimeMinute);
}