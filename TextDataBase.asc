// ==========================================
// TextDataBase.asc (SCRIPT)
// ==========================================
//
// Notes:
// - Loads simple key/value translation files from $DATA$/Texts/
// - Always loads English first as a fallback, then overlays the selected language
// - Supports \n, \t, \r\n, \", \\ escape sequences in values
// - Supports basic token replacement: {0}..{3}
//
// File format:
//   # comment
//   KEY.PATH = Some text with \n newlines and {0} tokens
//

// ==========================================
// Globals
// ==========================================
Dictionary* gText;
String gTextLang;

// ==========================================
// TrimWhitespace
// ==========================================
// Notes:
// - Trims leading/trailing spaces and tabs only (not full unicode whitespace)
// - Returns "" if the string is all whitespace
String TrimWhitespace(String s){
  if (String.IsNullOrEmpty(s)){
    return s;
  }

  int start = 0;
  int end = s.Length - 1;

  while (start <= end){
    int c = s.Chars[start];
    if (c != ' ' && c != '\t'){
      break;
    }
    start++;
  }

  while (end >= start){
    int c = s.Chars[end];
    if (c != ' ' && c != '\t'){
      break;
    }
    end--;
  }

  if (start > end){
    return "";
  }

  return s.Substring(start, end - start + 1);
}

// ==========================================
// UnescapeText
// ==========================================
// Notes:
// - Converts text file escape sequences into actual characters
// - Order matters: do \\ last so \n remains detectable first
String UnescapeText(String s){
  s = s.Replace("\\r\\n", "\n", true);
  s = s.Replace("\\n", "\n", true);
  s = s.Replace("\\t", "\t", true);
  s = s.Replace("\\\"", "\"", true);
  s = s.Replace("\\\\", "\\", true);
  return s;
}

// ==========================================
// TextDB_LoadFileInto
// ==========================================
// Notes:
// - Reads a key/value file and inserts into dict
// - Lines beginning with # are comments
// - Warns on malformed lines and duplicate keys (overwrites duplicates)
void TextDB_LoadFileInto(Dictionary* dict, String path){
  File* f = File.Open(path, eFileRead);
  if (f == null){
    System.Log(eLogError, "TextDB: Failed to open '%s'", path);
    return;
  }

  int lineNo = 0;

  while (!f.EOF){
    lineNo++;

    String line = f.ReadRawLineBack();
    line = TrimWhitespace(line);

    if (line.Length == 0){
      continue;
    }
    if (line.StartsWith("#")){
      continue;
    }

    int eq = line.IndexOf("=");
    if (eq < 0){
      System.Log(eLogWarn, "TextDB: Ignoring malformed line %d in '%s'", lineNo, path);
      continue;
    }

    String key = TrimWhitespace(line.Substring(0, eq));
    String val = TrimWhitespace(line.Substring(eq + 1, line.Length - (eq + 1)));
    val = UnescapeText(val);

    if (key.Length == 0){
      System.Log(eLogWarn, "TextDB: Empty key at line %d in '%s'", lineNo, path);
      continue;
    }

    if (dict.Contains(key)){
      System.Log(eLogWarn, "TextDB: Duplicate key '%s' at line %d in '%s' (overwriting)", key, lineNo, path);
    }

    dict.Set(key, val);
  }

  f.Close();
}

// ==========================================
// TextDB_SetLanguage
// ==========================================
// Notes:
// - Clears existing dictionary contents
// - Loads English fallback first, then overlays selected language (if not "en")
void TextDB_SetLanguage(String lang){
  if (gText == null){
    gText = Dictionary.Create();
  }

  if (String.IsNullOrEmpty(lang)){
    lang = "en";
  }

  gTextLang = lang;

  gText.Clear();

  TextDB_LoadFileInto(gText, "$DATA$/Texts/strings.en.txt");

  if (gTextLang != "en"){
    String langPath = String.Format("$DATA$/Texts/strings.%s.txt", gTextLang);
    TextDB_LoadFileInto(gText, langPath);
  }

  System.Log(eLogInfo, "TextDB: Active language '%s'", gTextLang);
}

// ==========================================
// TextDB_Init
// ==========================================
// Notes:
// - Creates dictionary if needed, then sets language (loads files)
void TextDB_Init(String lang){
  if (gText == null){
    gText = Dictionary.Create();
  }

  TextDB_SetLanguage(lang);
}

// ==========================================
// TextDB_GetLanguage
// ==========================================
String TextDB_GetLanguage(){
  return gTextLang;
}

// ==========================================
// I
// ==========================================
// Notes:
// - Integer to String helper for TF tokens
String I(int value){
  return String.Format("%d", value);
}

// ==========================================
// T
// ==========================================
// Notes:
// - Translation lookup by key
// - If called before init, logs and returns key (fail loud)
// - If missing key, logs and returns key (fail loud but playable)
String T(String key){
  if (gText == null){
    System.Log(eLogWarn, "TextDB: T('%s') called before init", key);
    return key;
  }

  if (gText.Contains(key)){
    return gText.Get(key);
  }

  System.Log(eLogWarn, "TextDB: Missing key '%s' (lang '%s')", key, gTextLang);
  return key;
}

// ==========================================
// TF
// ==========================================
// Notes:
// - Convenience wrapper (no tokens)
String TF(String key){
  return T(key);
}

// ==========================================
// ApplyTokens
// ==========================================
// Notes:
// - Replaces {0}..{3} in a string with provided parameters
String ApplyTokens(String s, String p0, String p1, String p2, String p3){
  s = s.Replace("{0}", p0, true);
  s = s.Replace("{1}", p1, true);
  s = s.Replace("{2}", p2, true);
  s = s.Replace("{3}", p3, true);
  return s;
}

// ==========================================
// TF1..TF4
// ==========================================
// Notes:
// - Looks up translation then applies tokens
String TF1(String key, String p0){
  return ApplyTokens(T(key), p0, "", "", "");
}

String TF2(String key, String p0, String p1){
  return ApplyTokens(T(key), p0, p1, "", "");
}

String TF3(String key, String p0, String p1, String p2){
  return ApplyTokens(T(key), p0, p1, p2, "");
}

String TF4(String key, String p0, String p1, String p2, String p3){
  return ApplyTokens(T(key), p0, p1, p2, p3);
}
