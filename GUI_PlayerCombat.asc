// ==============================
// GUI_PlayerCombat.asc (module script)
// ==============================

// Attack
function btnAttack_OnClick(GUIControl *control, MouseButton button)
{
	Combat_PlayerAttack();
}

// Melee Next
function btnMeleeNext_OnClick(GUIControl *control, MouseButton button)
{
	Combat_SelectNextMelee();
}

// Melee Previous
function btnMeleePrev_OnClick(GUIControl *control, MouseButton button)
{
	Combat_SelectPrevMelee();
}

// Defend
function btnDefend_OnClick(GUIControl *control, MouseButton button)
{
	Combat_PlayerDefend();
}

// Potion
function btnPotion_OnClick(GUIControl *control, MouseButton button)
{
	Combat_PlayerPotion();
}

// Spell
function btnSpell_OnClick(GUIControl *control, MouseButton button)
{
	Combat_PlayerCast();
}

// Spell Next
function btnSpellNext_OnClick(GUIControl *control, MouseButton button)
{
	Combat_SelectNextSpell();
}

// Spell Previous
function btnSpellPrev_OnClick(GUIControl *control, MouseButton button)
{
	Combat_SelectPrevSpell();
}
