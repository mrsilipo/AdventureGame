// room script file

function room_Load(){
  gInputName.Visible = true;
  txtNameInput.Text = "Izabella";
}

function StartNewGameAs(StatClass _class){
  Stat_InitClassBaseTable();                              // Always rebuild the class table (safe + cheap)
  if (gHeroStats == null){ gHeroStats = new CharSheet; }  // Create hero sheet once
  Stat_ApplyBaseClass(_class, gHeroStats);                // Apply class stats
  gHeroName = txtNameInput.Text;                          // Assign Hero's name
  gStatsReady = true;                                     // Mark RPG stats layer ready for systems that guard on gStatsReady (combat, etc.)
  Combat_Init();                                          // Initiate Combat System
  gClockRunning = true;                                   // Start the DayNight Clock
  Time_Init(1, 7, 30, 0);                                 // Time of Day Example: Day 1, 07:30:00 AM

  // ==========================================

  // GUI Cleanup
  // Hide the gClassInfo 
  gInputName.Visible = false;
  gClassInfo.Visible = false;
  lblClassDesc.Text = "";

  // Turn gameplay on
  gStatusline.Visible = true;
  gIconbar.Visible = true;
  cEgo.on = true;
  
  // Return Cursors
  CursorReturnPrevious();

  // ==========================================

  // Jump into the game
  player.ChangeRoom(ROOM_FIRST_GAME, START_X, START_Y);
}

function room_Unload()
{
  // Play music for 1st room?
}

// Go back to Main Menu
function hBack_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  player.ChangeRoom(1, 0, 0);
}

function hFighter_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  StartNewGameAs(eClassFighter);
}
function hFighter_MouseMove(Hotspot *theHotspot)
{
  gClassInfo.Visible = true;
  lblClassDesc.Text = T("PICKCLASS.FIGHTER.DESC");
}

function hMage_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  StartNewGameAs(eClassMage);
}
function hMage_MouseMove(Hotspot *theHotspot)
{
  gClassInfo.Visible = true;
  lblClassDesc.Text = T("PICKCLASS.MAGE.DESC");
}

function hTheif_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  StartNewGameAs(eClassTheif);
}
function hTheif_MouseMove(Hotspot *theHotspot)
{
  gClassInfo.Visible = true;
  lblClassDesc.Text = T("PICKCLASS.THEIF.DESC");
}
function hMouseOff_MouseMove(Hotspot *theHotspot)
{
  gClassInfo.Visible = false;
  lblClassDesc.Text = "";
}