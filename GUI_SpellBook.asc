// Close SpellBook
function btnSpellBookClose_OnClick(GUIControl *control, MouseButton button)
{
  // Disable GUI Icon Bar and Force Pointer Mode
  CursorEnableMouseModes();
  guiSpellBook.Visible = false;
  gIconbar.Visible = true;
  
}
