// room script file
function room_Load(){
  // Hide gameplay UI
  gStatusline.Visible = false;
  gIconbar.Visible = false;
  
  // Hide player
  cEgo.on = false;
  
  CursorDisableMouseModes();
  CursorForcePointerMode();
 }

function hNewGame_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  player.ChangeRoom(2, 0, 0);
}

function hLoadGame_Pointer(Hotspot *theHotspot, CursorMode mode)
{
  RestoreGameDialog();
}

function hQuit_AnyClick(Hotspot *theHotspot, CursorMode mode)
{
  QuitGame(false);
}

