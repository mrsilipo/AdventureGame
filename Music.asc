// ==========================================
// Music.asc (SCRIPT)
// ==========================================

AudioChannel* gMusicChannel;
AudioChannel* gFadeInChannel;
bool gCrossfading = false;
int gCrossfadeStep = 2;
AudioChannel* gOverrideMusicChannel;
AudioClip* gCurrentMusic;
AudioClip* gPreviousMusic;

void MusicSystem_Init()
{
  gMusicChannel = null;
  gFadeInChannel = null;
  gCurrentMusic = null;
  gCrossfading = false;
  gCrossfadeStep = 2;
}

void Music_Play(AudioClip* _clip, bool _repeat){
  if (_clip == null) return;

  if ((gMusicChannel != null) && (gMusicChannel.IsPlaying)){
    if (gMusicChannel.PlayingClip == _clip){
      return;
    }

    gPreviousMusic = gMusicChannel.PlayingClip;
    gMusicChannel.Stop();
  }

  gCurrentMusic = _clip;

  if (_repeat) {
    gMusicChannel = _clip.Play(eAudioPriorityHigh, eRepeat);
  } else {
    gMusicChannel = _clip.Play(eAudioPriorityHigh, eOnce);
  }

  if (gMusicChannel != null){
    gMusicChannel.Volume = 100;
  }
}

void Music_PlayPrevious(){
  if (gPreviousMusic == null) return;
  Music_Play(gPreviousMusic, true);
}

void Music_CrossfadeTo(AudioClip* _newClip){
  if (_newClip == null) return;

  // Already the current live music
  if ((gMusicChannel != null) && (gMusicChannel.IsPlaying))
  {
    if (gMusicChannel.PlayingClip == _newClip)
    {
      return;
    }
  }

  // Already fading toward this clip
  if ((gFadeInChannel != null) && (gFadeInChannel.IsPlaying)){
    if (gFadeInChannel.PlayingClip == _newClip){
      return;
    }
  }

  // If nothing is currently playing, just play normally
  if ((gMusicChannel == null) || (!gMusicChannel.IsPlaying)){
    Music_Play(_newClip, true);
    return;
  }

  // Optional: stop any previous unfinished fade-in channel
  if ((gFadeInChannel != null) && (gFadeInChannel.IsPlaying)){
    gFadeInChannel.Stop();
  }

  gFadeInChannel = _newClip.Play(eAudioPriorityHigh, eRepeat);

  if (gFadeInChannel == null) return;

  gFadeInChannel.Volume = 0;
  gCurrentMusic = _newClip;
  gCrossfading = true;
}

void Music_UpdateCrossfade(){
  if (!gCrossfading) return;

  if ((gMusicChannel != null) && (gMusicChannel.IsPlaying)){
    int _outVolume = gMusicChannel.Volume - gCrossfadeStep;

    if (_outVolume < 0)
    {
      _outVolume = 0;
    }

    gMusicChannel.Volume = _outVolume;
  }

  if ((gFadeInChannel != null) && (gFadeInChannel.IsPlaying)){
    int _inVolume = gFadeInChannel.Volume + gCrossfadeStep;

    if (_inVolume > 100)
    {
      _inVolume = 100;
    }

    gFadeInChannel.Volume = _inVolume;
  }

  if ((gFadeInChannel != null) && (gFadeInChannel.IsPlaying) && (gFadeInChannel.Volume >= 100)){
    gFadeInChannel.Volume = 100;

    if ((gMusicChannel != null) && (gMusicChannel.IsPlaying))
    {
      gMusicChannel.Stop();
    }

    gMusicChannel = gFadeInChannel;
    gFadeInChannel = null;
    gCrossfading = false;
  }
}

void Music_Stop(){
  if ((gMusicChannel != null) && (gMusicChannel.IsPlaying)){
    gMusicChannel.Stop();
  }

  gMusicChannel = null;
  gCurrentMusic = null;
}

void Music_StopAll(){
  if ((gMusicChannel != null) && (gMusicChannel.IsPlaying))
  {
    gMusicChannel.Stop();
  }

  if ((gOverrideMusicChannel != null) && (gOverrideMusicChannel.IsPlaying))
  {
    gOverrideMusicChannel.Stop();
  }

  gMusicChannel = null;
  gOverrideMusicChannel = null;
  gCurrentMusic = null;
}

void Sfx_Play(AudioClip* _clip){
  if (_clip == null) return;
  _clip.Play(eAudioPriorityNormal, eOnce);
}

void Sfx_Stop(AudioClip* _clip){
  if (_clip == null) return;
  _clip.Stop();
}

void Sfx_StopAll(){
  int i = 0;

  while (i < System.AudioChannelCount){
    AudioChannel* _channel = System.AudioChannels[i];

    if ((_channel != null) && (_channel.IsPlaying)){
      AudioClip* _clip = _channel.PlayingClip;

      if ((_clip != null) && (_clip.Type == eAudioTypeSound)){
        _channel.Stop();
      }
    }

    i++;
  }
}

export gMusicChannel;
export gFadeInChannel;
export gCrossfading;
export gCrossfadeStep;
export gOverrideMusicChannel;
export gCurrentMusic;
export gPreviousMusic;