// Math Functions - Script File

// Retuirn the max int value from the 2 comparissons
int MaxInt(int _value1, int _value2) {
  if (_value1 > _value2) {
    return _value1;
  }
  else {
    return _value2;
  }
}

// Retuirn the max float value from the 2 comparissons
float MaxFloat(float _value1, float _value2){
  if (_value1 > _value2) {
    return _value1;
  }
  else {
    return _value2;
  }
}

float ClampFloat(float _value, float _min, float _max){
    if (_value < _min)
        return _min;

    if (_value > _max)
        return _max;

    return _value;
}

int ClampInt(int _value, int _min, int _max){
    if (_value < _min)
        return _min;

    if (_value > _max)
        return _max;

    return _value;
}