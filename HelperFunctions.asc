// ==========================================
// HelperFunctions.asc (SCRIPT)
// ==========================================

// ==========================================
// Walk to Interaction
// ==========================================
void WalkToInteraction(int _x, int _y, int _dir, int _wait){
	player.Walk(_x, _y, true);
 	player.FaceDirection(_dir);
 	Wait(_wait);
}

// ==========================================
// Mouse Modes
// ==========================================

// Module/global script scope
CursorMode gPrevMouseMode = eModeWalkto;
bool gHasPrevMouseMode = false;

void CursorDisableMouseModes(){
	// Store current mode BEFORE changing anything
  	gPrevMouseMode = Mouse.Mode;
  	gHasPrevMouseMode = true;

	// Disable all other mouse modes
	Mouse.DisableMode(eModeWalkto);
	Mouse.DisableMode(eModeLookat);
	Mouse.DisableMode(eModeInteract);
	Mouse.DisableMode(eModeTalkto);
	Mouse.DisableMode(eModeWait);

	// Force pointer mode
	Mouse.UseModeGraphic(eModeWalkto);
	Mouse.Mode = eModeWalkto;
}

void CursorEnableMouseModes(){
	// Enable all other mouse modes
	Mouse.EnableMode(eModeWalkto);
	Mouse.EnableMode(eModeLookat);
	Mouse.EnableMode(eModeInteract);
	Mouse.EnableMode(eModeTalkto);
	Mouse.EnableMode(eModeWait);
}

void CursorForcePointerMode(){
	// Force pointer mode
	Mouse.UseModeGraphic(eModePointer);
	Mouse.Mode = eModePointer;
}

void CursorReturnPrevious(){
	// Make sure modes are enabled first, otherwise restore may fail / behave oddly
	CursorEnableMouseModes();

	if (gHasPrevMouseMode){
		Mouse.UseModeGraphic(gPrevMouseMode);
		Mouse.Mode = gPrevMouseMode;
	} else {
		// Safe fallback
		Mouse.UseModeGraphic(eModeWalkto);
		Mouse.Mode = eModeWalkto;
	}
}

// ==========================================
// Iconbar GUI
// ==========================================

// A function to enable or disable all icons on the Iconbar
void IconBarGUI_Enable(bool enable){
	btnIconWalk.Enabled = enable;
  btnIconRun.Enabled = enable;
  btnIconExamine.Enabled = enable;
  btnIconInteract.Enabled = enable;
  btnIconTalk.Enabled = enable;
  btnIconMore.Enabled = enable;
  btnIconMagic.Enabled = enable;
  btnIconInv.Enabled = enable;
  btnSave.Enabled = enable;
  btnIconPanel.Enabled = enable;
}

// ==========================================
// Bar
// ==========================================
void UpdateBar(Button* _btn_id, int _value, int _value_max, int _bar_width) {
  _btn_id.Width = (_value * _bar_width) / _value_max;
}

// ==========================================
// Exports
// ==========================================

export gPrevMouseMode;
export gHasPrevMouseMode;

