// LIT TORCH
// ==========================================
function iInvLitTorch_Look(InventoryItem *theItem, CursorMode mode){
    VOICEOVER = aVO_Inv_TorchLitLook.Play();
    Display(T("INV.TORCH.LIT.LOOK"));
    VOICEOVER.Stop();
}