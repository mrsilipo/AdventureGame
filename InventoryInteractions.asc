// ==========================================
// InventoryInteractions.asc (SCRIPT)
// ==========================================

// ==========================================
// Money Pouch
// ==========================================
function iCoinPouch_Look(InventoryItem *theItem, CursorMode mode){
  if (gHeroStats.gold == 0){
    Display(T("INV.COINPOUCH.LOOK.EMPTY"));
  } else {
    Display(TF2("INV.COINPOUCH.LOOK.CARRY", I(gHeroStats.gold), T("GOLD.CURRENCY")));
  }
}

// ==========================================
// Torch
// ==========================================
function iTorch_Look(InventoryItem *theItem, CursorMode mode){
    if (gInventoryTorchLit){
      Display(T("INV.TORCH.LIT.LOOK"));
    } else {
      Display(T("INV.TORCH.LOOK"));
    }
}

function iTorch_UseInv(InventoryItem *theItem, CursorMode mode)
{
  if (player.ActiveInventory == iFlint || player.ActiveInventory == iDagger){
    if (player.HasInventory(iDagger) && player.HasInventory(iFlint)){
      if (gInventoryTorchLit){
        Display(T("INV.TORCH.LIT.INV.LIGHT"));
      } else {
        Display(T("INV.TORCH.INV.LIGHT"));
        iTorch.Name = T("INV.TORCH.LIT.NAME");
        player.ActiveInventory = iTorch;
        gInventoryTorchLit = true;
      }
    }
    else if (!player.HasInventory(iDagger)){
      Display(T("INV.TORCH.LIT.INV.NODAGGER"));
    } else if (!player.HasInventory(iFlint)){
      Display(T("INV.TORCH.LIT.INV.NOFLINT"));
    }
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// Dagger
// ==========================================
function iDagger_Look(InventoryItem *theItem, CursorMode mode){
  Display(T("INV.DAGGER.LOOK"));
}

function iDagger_UseInv(InventoryItem *theItem, CursorMode mode){
  if (player.ActiveInventory == iFlint){
    Display(T("INV.DAGGER.FLINT"));
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// Flint
// ==========================================
function iFlint_Look(InventoryItem *theItem, CursorMode mode){
  Display(T("INV.LOOK.FLINT"));
}

function iFlint_UseInv(InventoryItem *theItem, CursorMode mode){
  if (player.ActiveInventory == iFlint){
    Display(T("INV.DAGGER.FLINT"));
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// LIGHTING THE TINDERBOX
// ==========================================
function WrapClothOnStick(){
  player.LoseInventory(iInvStick);
  player.LoseInventory(iInvCloth);
  player.AddInventory(iInvUnlitTorch);  
  player.ActiveInventory = iInvUnlitTorch;
  VOICEOVER = aVO_Inv_StickUseInvCloth.Play();
  Display(T("INV.STICK.USEINV.CLOTH"));
  VOICEOVER.Stop();
}

function LightUnlitTorch(){
  player.LoseInventory(iInvUnlitTorch);
  player.AddInventory(iInvLitTorch);  
  player.ActiveInventory = iInvLitTorch;
  aSFX002.Play();
  Wait(30);
  VOICEOVER = aVO_Inv_TorchUnitUseInvTinderbox.Play();
  Display(T("INV.TORCH.UNLIT.TINDERBOX"));
  VOICEOVER.Stop();
  aSFX_Point.Play();
}


// ==========================================
// STICK
// ==========================================

function iInvStick_Look(InventoryItem *theItem, CursorMode mode)
{
  VOICEOVER = aVO_Inv_StickLook.Play();
  Display(T("INV.STICK.LOOK"));
  VOICEOVER.Stop();
}

function iInvStick_UseInv(InventoryItem *theItem, CursorMode mode)
{
  if (player.ActiveInventory == iInvCloth){
    WrapClothOnStick();
  } else if (player.ActiveInventory == iInvTinderbox){
    VOICEOVER = aVO_Inv_StickUseInvTinderbox.Play();
    Display(T("INV.STICK.USEINV.TINDERBOX"));
    VOICEOVER.Stop();
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// CLOTH
// ==========================================

function iInvCloth_Look(InventoryItem *theItem, CursorMode mode)
{
  VOICEOVER = aVO_Inv_ClothLook.Play();
  Display(T("INV.CLOTH.LOOK"));
  VOICEOVER.Stop();
}

function iInvCloth_UseInv(InventoryItem *theItem, CursorMode mode)
{
  if (player.ActiveInventory == iInvStick){
    WrapClothOnStick();
  } else if (player.ActiveInventory == iInvTinderbox){
    VOICEOVER = aVO_Inv_ClothUseInvTinderbox.Play();
    Display(T("INV.CLOTH.USEINV.TINDERBOX"));
    VOICEOVER.Stop();
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// UNLIT TORCH
// ==========================================
function iInvUnlitTorch_Look(InventoryItem *theItem, CursorMode mode){
    Display(T("INV.TORCH.UNLIT.LOOK"));
}

function iInvUnlitTorch_UseInv(InventoryItem *theItem, CursorMode mode)
{
  if (player.ActiveInventory == iInvTinderbox){
    LightUnlitTorch();
  } else {
    Display(T("INV.INV"));
  }
}

// ==========================================
// TINDERBOX
// ==========================================
function iInvTinderbox_Look(InventoryItem *theItem, CursorMode mode){
    VOICEOVER = aVO_Inv_TinderboxLook.Play();
    Display(T("INV.TINDERBOX.LOOK"));
    VOICEOVER.Stop();
}

function iInvTinderbox_UseInv(InventoryItem *theItem, CursorMode mode)
{
  if (player.ActiveInventory == iInvUnlitTorch){
    LightUnlitTorch();
  } else if (player.ActiveInventory == iInvCloth){
    VOICEOVER = aVO_Inv_ClothUseInvTinderbox.Play();
    Display(T("INV.CLOTH.USEINV.TINDERBOX"));
    VOICEOVER.Stop();
  } else if (player.ActiveInventory == iInvStick){
    VOICEOVER = aVO_Inv_StickUseInvTinderbox.Play();
    Display(T("INV.STICK.USEINV.TINDERBOX"));
    VOICEOVER.Stop();
  } else {
    Display(T("INV.INV"));
  }
}

