// ==========================================
// CombatSystem.asc (SCRIPT)
// ==========================================
CombatRuntime gCombat;

MonsterTemplate _monster_db[eMonsterCount];

void MonsterData(MonsterKind kind){
  switch(kind){
    case eMonsterToad:
      _monster_db[eMonsterToad].name = "Toad";
      _monster_db[eMonsterToad].death = "toad";
      _monster_db[eMonsterToad].victory = "You toadily crush it!";
      _monster_db[eMonsterToad].kind = eMonsterToad;

      _monster_db[eMonsterToad].base[eStatStrength] = 5;
      _monster_db[eMonsterToad].base[eStatVitality] = 5;
      _monster_db[eMonsterToad].base[eStatIntelligence] = 2;
      _monster_db[eMonsterToad].base[eStatAgility] = 5;
      _monster_db[eMonsterToad].base[eStatKinesthesia] = 3;
      _monster_db[eMonsterToad].base[eStatCommunication] = 1;

      _monster_db[eMonsterToad].hp_max = 24;
      _monster_db[eMonsterToad].mp_max = 4;
      _monster_db[eMonsterToad].atb_speed = 3;

      // Behaviour stats on a strict 0..10 scale
      // Fighter Behaviour Profile:
      // _monster_db[eMonsterToad].aggression = 7;
      // _monster_db[eMonsterToad].defensiveness = 3;
      // _monster_db[eMonsterToad].specialAttack = 4;
      // _monster_db[eMonsterToad].magicUse = 0;

      // Magic Behaviour Profile:
      _monster_db[eMonsterToad].aggression = 2;
      _monster_db[eMonsterToad].defensiveness = 2;
      _monster_db[eMonsterToad].specialAttack = 3;
      _monster_db[eMonsterToad].magicUse = 8;

      // Moves
      _monster_db[eMonsterToad].move_count = 4;

      // 1: Attack - No MP
      _monster_db[eMonsterToad].move_names[0] = "Tongue Lash";
      _monster_db[eMonsterToad].move_power[0] = 2;
      _monster_db[eMonsterToad].move_mp_cost[0] = 0;
      _monster_db[eMonsterToad].move_category[0] = eMoveNormalAttack;

      // 2: Special Attack - No MP
      _monster_db[eMonsterToad].move_names[1] = "Toad Toxin";
      _monster_db[eMonsterToad].move_power[1] = 8;
      _monster_db[eMonsterToad].move_mp_cost[1] = 0;
      _monster_db[eMonsterToad].move_category[1] = eMoveSpecialAttack;

      // 3: Magic Attack - MP
      _monster_db[eMonsterToad].move_names[2] = "Toad Spit";
      _monster_db[eMonsterToad].move_power[2] = 5;
      _monster_db[eMonsterToad].move_mp_cost[2] = 2;
      _monster_db[eMonsterToad].move_category[2] = eMoveOffensiveMagic;

      // 4: Magic Healing - MP
      _monster_db[eMonsterToad].move_names[3] = "Healing Croak";
      _monster_db[eMonsterToad].move_power[3] = 5;
      _monster_db[eMonsterToad].move_mp_cost[3] = 2;
      _monster_db[eMonsterToad].move_category[3] = eMoveHealingMagic;
      break;
  }
}

int ClampInt(int value, int minv, int maxv) {
  if (value < minv) return minv;
  if (value > maxv) return maxv;
  return value;
}

void Combat_SetMeleeMove(int slot, String name, int power) {
  if (slot < 0 || slot >= 5) return;
  gCombat.melee_names[slot] = name;
  gCombat.melee_power[slot] = power;
}

void Combat_SetSpellMove(int slot, String name, int power, int mp_cost) {
  if (slot < 0 || slot >= 5) return;
  gCombat.spell_names[slot] = name;
  gCombat.spell_power[slot] = power;
  gCombat.spell_mp_cost[slot] = mp_cost;
}

void Combat_LoadEnemyFromMonsterData(MonsterKind kind, CharSheet* enemy){
  int i = 0;
  MonsterData(kind);

  while (i < STAT_COUNT){
    enemy.base[i] = _monster_db[kind].base[i];
    enemy.temp[i] = 0;
    i++;
  }

  Stat_RecalcDerived(enemy);

  enemy.hp_max = _monster_db[kind].hp_max;
  enemy.mp_max = _monster_db[kind].mp_max;
  enemy.hp = enemy.hp_max;
  enemy.mp = enemy.mp_max;
}

void Combat_RegisterStarterMoves() {
  gCombat.known_melee_count = 1;
  gCombat.selected_melee = 0;
  Combat_SetMeleeMove(0, "Strike", 6);

  gCombat.known_spell_count = 1;
  gCombat.selected_spell = 0;
  Combat_SetSpellMove(0, "Spark", 8, 2);
}

void Combat_Init() {
  gCombat.active = false;
  gCombat.state = eCombatInactive;
  gCombat.atb_max = 100;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;
  Combat_RegisterStarterMoves();
}

bool Combat_IsActive() {
  return gCombat.active;
}

bool Combat_PlayerHasHealingPotion() {
  return (player.InventoryQuantity[iHealingPotion.ID] > 0);
}

void Combat_StartByKind(MonsterKind kind) {
  if (!gStatsReady) return;
  if (gCombat.enemy == null) {
    gCombat.enemy = new CharSheet;
  }

  // Disable GUI Icon Bar and Force Pointer Mode
  CursorDisableMouseModes();
  CursorForcePointerMode();
  IconBarGUI_Enable(false);

  // Show Combat GUI
  guiBattle.Visible = true;
  guiBattlePlayerStatus.Visible = true;

  // Load Monster Data
  gCombat.enemy_kind = kind;
  Combat_LoadEnemyFromMonsterData(kind, gCombat.enemy);

  // Play Battle Music
  Music_Play(aBattle, true); // need to make this contextual to the enemy

  // ATBs
  gCombat.player_atb = 0;
  gCombat.enemy_atb = 0;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;
  gCombat.player_defending = false;
  gCombat.enemy_defending = false;

  lblBattleLog.Text = String.Format("Battle started! A %s appears.", _monster_db[kind].name);

  gCombat.active = true;
  gCombat.state = eCombatRunning;
}

void Combat_ClearEnemyState()
{
  int i = 0;

  if (gCombat.enemy == null) return;

  while (i < STAT_COUNT)
  {
    gCombat.enemy.base[i] = 0;
    gCombat.enemy.temp[i] = 0;
    i++;
  }

  gCombat.enemy.hp = 0;
  gCombat.enemy.hp_max = 0;
  gCombat.enemy.mp = 0;
  gCombat.enemy.mp_max = 0;
}

void Combat_End() {

  // Hide Combat GUI
  guiBattle.Visible = false;
  guiBattlePlayerStatus.Visible = false;

  if (gCombat.state == eCombatVictory){
    // Re-enable GUI Icon Bar and Mouse Modes
    CursorEnableMouseModes();
    CursorReturnPrevious();
    IconBarGUI_Enable(true);
    // Return to the previous music - in the case of GameOver this will be instantly overridden
    Music_PlayPrevious();

    // Display the victory message
    Display(_monster_db[gCombat.enemy_kind].victory);
  } else {
    GameOverGui_Open(_monster_db[gCombat.enemy_kind].death);
  }

  // End Combat
  gCombat.active = false;
  gCombat.state = eCombatInactive;

  // Data Clean Up
  Combat_ClearEnemyState();
  gCombat.player_atb = 0;
  gCombat.enemy_atb = 0;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;

  gCombat.player_defending = false;
  gCombat.enemy_defending = false;

  lblBattleLog.Text = "";
}

void Combat_CheckEndConditions() {
  // Victory
  if (gCombat.enemy.hp <= 0) {
    gCombat.enemy.hp = 0;
    gCombat.state = eCombatVictory;
    Combat_End();
    return;
  }

  // Defeat
  if (gHeroStats.hp <= 0) {
    gHeroStats.hp = 0;
    gCombat.state = eCombatDefeat;
    Combat_End();
    return;
  }
}

int Combat_BehaviourClamp(int value){
  return ClampInt(value, 0, 10);
}

int Combat_BehaviourWeight(int value){
  value = Combat_BehaviourClamp(value);
  return value * value;
}

int Combat_EnemyDamageBasic() {
  int atk = Stat_GetEffective(eStatStrength, gCombat.enemy);
  int dmg = atk + 4;
  if (dmg < 1) dmg = 1;
  if (gCombat.player_defending) dmg = dmg / 2;
  return dmg;
}

void Combat_PlayerAttack() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblBattleLog.Text = "ATB not full yet.";
    return;
  }

  int basePower = gCombat.melee_power[gCombat.selected_melee];
  String moveName = gCombat.melee_names[gCombat.selected_melee];
  int dmg = Stat_GetEffective(eStatStrength, gHeroStats) + basePower;
  if (dmg < 1) dmg = 1;
  if (gCombat.enemy_defending) dmg = dmg / 2;

  gCombat.enemy.hp = ClampInt(gCombat.enemy.hp - dmg, 0, gCombat.enemy.hp_max);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  lblBattleLog.Text = String.Format("You use %s for %d damage.", moveName, dmg);
  Combat_CheckEndConditions();
}

void Combat_PlayerDefend() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblBattleLog.Text = "ATB not full yet.";
    return;
  }

  gCombat.player_defending = true;
  gCombat.player_atb = 0;
  lblBattleLog.Text = "You brace for impact.";
}

void Combat_PlayerCast() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblBattleLog.Text = "ATB not full yet.";
    return;
  }

  int spellCost = gCombat.spell_mp_cost[gCombat.selected_spell];
  int spellPower = gCombat.spell_power[gCombat.selected_spell];
  String spellName = gCombat.spell_names[gCombat.selected_spell];

  if (gHeroStats.mp < spellCost) {
    lblBattleLog.Text = "Not enough MP.";
    return;
  }

  Stat_ModMP(-spellCost, gHeroStats);

  int intstat = Stat_GetEffective(eStatIntelligence, gHeroStats);
  int dmg = intstat + spellPower;
  if (gCombat.enemy_defending) dmg = dmg / 2;
  if (dmg < 1) dmg = 1;

  gCombat.enemy.hp = ClampInt(gCombat.enemy.hp - dmg, 0, gCombat.enemy.hp_max);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  lblBattleLog.Text = String.Format("You cast %s for %d damage.", spellName, dmg);
  Combat_CheckEndConditions();
}

void Combat_PlayerPotion() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblBattleLog.Text = "ATB not full yet.";
    return;
  }

  if (!Combat_PlayerHasHealingPotion()) {
    lblBattleLog.Text = "No Healing Potions left.";
    return;
  }

  // Call your existing inventory script function.
  iHealingPotion_Drink();

  gCombat.player_atb = 0;
  gCombat.player_defending = false;
  lblBattleLog.Text = "You drink a Healing Potion.";
}

int Combat_GetEnemyDefendWeight()
{
  int weight = Combat_BehaviourWeight(_monster_db[gCombat.enemy_kind].defensiveness);

  if (gCombat.enemy.hp <= (gCombat.enemy.hp_max / 3))
  {
    weight = weight + 10;
  }

  return weight;
}

int Combat_GetEnemyMoveWeight(int move_index)
{
  MonsterKind kind = gCombat.enemy_kind;
  EnemyMoveCategory category = _monster_db[kind].move_category[move_index];
  int mp_cost = _monster_db[kind].move_mp_cost[move_index];

  // Cannot use moves the monster cannot afford
  if (gCombat.enemy.mp < mp_cost)
  {
    return 0;
  }

  switch (category)
  {
    case eMoveNormalAttack:
      return Combat_BehaviourWeight(_monster_db[kind].aggression);

    case eMoveSpecialAttack:
      return Combat_BehaviourWeight(_monster_db[kind].specialAttack);

    case eMoveOffensiveMagic:
      return Combat_BehaviourWeight(_monster_db[kind].magicUse);

    case eMoveHealingMagic:
      if (gCombat.enemy.hp >= (gCombat.enemy.hp_max / 2))
      {
        return 0;
      }

      return Combat_BehaviourWeight(_monster_db[kind].magicUse);
  }

  return 0;
}

int Combat_FindEnemyFallbackMove()
{
  int i = 0;
  MonsterKind kind = gCombat.enemy_kind;

  // First prefer any usable normal attack
  while (i < _monster_db[kind].move_count)
  {
    if (_monster_db[kind].move_category[i] == eMoveNormalAttack)
    {
      if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
      {
        return i;
      }
    }

    i++;
  }

  i = 0;

  // Then prefer any usable special attack
  while (i < _monster_db[kind].move_count)
  {
    if (_monster_db[kind].move_category[i] == eMoveSpecialAttack)
    {
      if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
      {
        return i;
      }
    }

    i++;
  }

  i = 0;

  // Then any other usable move
  while (i < _monster_db[kind].move_count)
  {
    if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
    {
      return i;
    }

    i++;
  }

  return -1;
}

int Combat_ChooseEnemyAction()
{
  int total_weight = 0;
  int move_weights[5];
  int i = 0;

  while (i < 5)
  {
    move_weights[i] = 0;
    i++;
  }

  i = 0;
  while (i < _monster_db[gCombat.enemy_kind].move_count)
  {
    move_weights[i] = Combat_GetEnemyMoveWeight(i);
    total_weight = total_weight + move_weights[i];
    i++;
  }

  int defend_weight = Combat_GetEnemyDefendWeight();
  total_weight = total_weight + defend_weight;

  if (total_weight <= 0)
  {
    return -1;
  }

  int roll = Random(total_weight - 1);

  i = 0;
  while (i < _monster_db[gCombat.enemy_kind].move_count)
  {
    if (roll < move_weights[i])
    {
      return i;
    }

    roll = roll - move_weights[i];
    i++;
  }

  return -1;
}

void Combat_EnemyUseMove(int move_index)
{
  MonsterKind kind = gCombat.enemy_kind;
  String enemyName = _monster_db[kind].name;
  String move_name = _monster_db[kind].move_names[move_index];
  int move_power = _monster_db[kind].move_power[move_index];
  int move_mp_cost = _monster_db[kind].move_mp_cost[move_index];
  EnemyMoveCategory category = _monster_db[kind].move_category[move_index];

  if (gCombat.enemy.mp < move_mp_cost)
  {
    gCombat.enemy_defending = true;
    gCombat.enemy_atb = 0;
    lblBattleLog.Text = String.Format("%s tries to use %s, but lacks the MP and defends.", enemyName, move_name);
    Combat_CheckEndConditions();
    return;
  }

  gCombat.enemy.mp = ClampInt(gCombat.enemy.mp - move_mp_cost, 0, gCombat.enemy.mp_max);

  if (category == eMoveHealingMagic)
  {
    int heal = Stat_GetEffective(eStatIntelligence, gCombat.enemy) + move_power;

    if (heal < 1) heal = 1;

    gCombat.enemy.hp = ClampInt(gCombat.enemy.hp + heal, 0, gCombat.enemy.hp_max);
    gCombat.enemy_defending = false;
    gCombat.enemy_atb = 0;

    lblBattleLog.Text = String.Format("%s uses %s and recovers %d HP.", enemyName, move_name, heal);
    Combat_CheckEndConditions();
    return;
  }

  int dmg = 0;

  if (category == eMoveOffensiveMagic)
  {
    dmg = Stat_GetEffective(eStatIntelligence, gCombat.enemy) + move_power;
  }
  else
  {
    dmg = Stat_GetEffective(eStatStrength, gCombat.enemy) + move_power;
  }

  if (dmg < 1) dmg = 1;
  if (gCombat.player_defending) dmg = dmg / 2;

  Stat_ModHP(-dmg, gHeroStats);

  gCombat.enemy_defending = false;
  gCombat.enemy_atb = 0;

  lblBattleLog.Text = String.Format("%s uses %s for %d damage.", enemyName, move_name, dmg);

  Combat_CheckEndConditions();
}

void Combat_EnemyTurn()
{
  if (!Combat_IsActive()) return;
  if (gCombat.enemy_atb < gCombat.atb_max) return;

  String enemyName = _monster_db[gCombat.enemy_kind].name;
  int action = Combat_ChooseEnemyAction();

  if (action < 0)
  {
    action = Combat_FindEnemyFallbackMove();
  }

  if (action < 0)
  {
    gCombat.enemy_defending = true;
    gCombat.enemy_atb = 0;
    lblBattleLog.Text = String.Format("%s defends.", enemyName);
    Combat_CheckEndConditions();
    return;
  }

  Combat_EnemyUseMove(action);
}

void Combat_SetPlayerCommandButtonsEnabled(bool enabled) {
  bool hasPotion = Combat_PlayerHasHealingPotion();

  btnAttack.Enabled = enabled;
  btnDefend.Enabled = enabled;
  btnRun.Enabled = enabled;
  btnSpell.Enabled = enabled;

  // Potion button follows both ATB readiness and inventory quantity
  btnPotion.Enabled = (enabled && hasPotion);
}

void Combat_UpdateHUD() {
  if (!Combat_IsActive()) return;

  sldPlayerHP.Max = gHeroStats.hp_max;
  sldPlayerHP.Value = gHeroStats.hp;

  sldPlayerMP.Max = gHeroStats.mp_max;
  sldPlayerMP.Value = gHeroStats.mp;

  sldPlayerATB.Max = gCombat.atb_max;
  sldPlayerATB.Value = gCombat.player_atb;

  if (gCombat.player_atb >= gCombat.atb_max) {
    Combat_SetPlayerCommandButtonsEnabled(true);
  }
  else {
    Combat_SetPlayerCommandButtonsEnabled(false);
  }

  // Optional enemy HUD (only if those controls exist in your GUI):
  // sldEnemyHP.Max = gCombat.enemy.hp_max;
  // sldEnemyHP.Value = gCombat.enemy.hp;
  // sldEnemyMP.Max = gCombat.enemy.mp_max;
  // sldEnemyMP.Value = gCombat.enemy.mp;
  // sldEnemyATB.Max = gCombat.atb_max;
  // sldEnemyATB.Value = gCombat.enemy_atb;
  // lblEnemyHP.Text = String.Format("HP %d/%d", gCombat.enemy.hp, gCombat.enemy.hp_max);
  // lblEnemyMP.Text = String.Format("MP %d/%d", gCombat.enemy.mp, gCombat.enemy.mp_max);
}

int Combat_ATBPointsPerSecondFromAgility(int agi) {
  // target scaling:
  // agility 3  -> 5.0s to fill (20 points/sec for atb_max=100)
  // agility 50 -> 1.0s to fill (100 points/sec)
  int a = ClampInt(agi, 3, 50);
  int pps = 20 + ((a - 3) * 80) / 47;
  return pps;
}

int Combat_GetATBSpeedDivisor() {
  int speed = sldSpeed.Value;
  if (speed < 1) speed = 1;
  return speed;
}

void Combat_ATBAdvancePlayerOneCycle() {
  int pps = Combat_ATBPointsPerSecondFromAgility(Stat_GetEffective(eStatAgility, gHeroStats));

  // fixed-point x100 so low speeds stay smooth on integer cycles
  int add_x100 = (pps * 100) / Combat_GetATBSpeedDivisor();
  gCombat.player_atb_accum_x100 = gCombat.player_atb_accum_x100 + add_x100;

  int whole = gCombat.player_atb_accum_x100 / 100;
  gCombat.player_atb_accum_x100 = gCombat.player_atb_accum_x100 % 100;

  gCombat.player_atb = ClampInt(gCombat.player_atb + whole, 0, gCombat.atb_max);
}

void Combat_ATBAdvanceEnemyOneCycle() {
  int pps = Combat_ATBPointsPerSecondFromAgility(Stat_GetEffective(eStatAgility, gCombat.enemy));

  int add_x100 = (pps * 100) / Combat_GetATBSpeedDivisor();
  gCombat.enemy_atb_accum_x100 = gCombat.enemy_atb_accum_x100 + add_x100;

  int whole = gCombat.enemy_atb_accum_x100 / 100;
  gCombat.enemy_atb_accum_x100 = gCombat.enemy_atb_accum_x100 % 100;

  gCombat.enemy_atb = ClampInt(gCombat.enemy_atb + whole, 0, gCombat.atb_max);
}

void Combat_Update() {
  if (!Combat_IsActive()) return;

  Combat_ATBAdvancePlayerOneCycle();
  Combat_ATBAdvanceEnemyOneCycle();

  Combat_EnemyTurn();
  Combat_UpdateHUD();
}

export gCombat;