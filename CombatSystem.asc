// ==========================================
// CombatSystem.asc (SCRIPT)
// ==========================================

CombatRuntime gCombat;

MonsterTemplate _monster_db[eMonsterCount];

// ====================================================================================
// Monster Database
// ====================================================================================

void MonsterData(MonsterKind kind){
  int i = 0;

  switch(kind){
    case eMonsterToad:
      i = 0;
      while (i < 5) {
        _monster_db[eMonsterToad].move_status[i] = COMBAT_STATUS_NONE;
        _monster_db[eMonsterToad].move_status_chance[i] = 0;
        _monster_db[eMonsterToad].move_status_duration[i] = 0;
        _monster_db[eMonsterToad].move_status_power[i] = 0;
        i++;
      }

      _monster_db[eMonsterToad].name = "Toad";
      _monster_db[eMonsterToad].death = "toad";
      _monster_db[eMonsterToad].victory = "You toadily crush it!";
      _monster_db[eMonsterToad].kind = eMonsterToad;

      _monster_db[eMonsterToad].base[eStatStrength] = 5;
      _monster_db[eMonsterToad].base[eStatVitality] = 5;
      _monster_db[eMonsterToad].base[eStatIntelligence] = 2;
      _monster_db[eMonsterToad].base[eStatAgility] = 5;
      _monster_db[eMonsterToad].base[eStatDexterity] = 3;
      _monster_db[eMonsterToad].base[eStatCommunication] = 1;

      _monster_db[eMonsterToad].hp_max = 24;
      _monster_db[eMonsterToad].mp_max = 4;
      _monster_db[eMonsterToad].atb_speed = 3;

      // Behaviour stats on a strict 0..10 scale
      // Fighter Behaviour Profile:
      // _monster_db[eMonsterToad].aggression = 7;
      // _monster_db[eMonsterToad].defensiveness = 3;
      // _monster_db[eMonsterToad].specialAttack = 4;
      // _monster_db[eMonsterToad].magicUse = 0;

      // Magic Behaviour Profile:
      _monster_db[eMonsterToad].aggression = 2;
      _monster_db[eMonsterToad].defensiveness = 2;
      _monster_db[eMonsterToad].specialAttack = 3;
      _monster_db[eMonsterToad].magicUse = 8;

      // Moves
      _monster_db[eMonsterToad].move_count = 4;

      // 1: Attack - No MP
      _monster_db[eMonsterToad].move_names[0] = "Tongue Lash";
      _monster_db[eMonsterToad].move_power[0] = 2;
      _monster_db[eMonsterToad].move_mp_cost[0] = 0;
      _monster_db[eMonsterToad].move_category[0] = eMoveNormalAttack;

      // 2: Special Attack - No MP
      _monster_db[eMonsterToad].move_names[1] = "Toad Toxin";
      _monster_db[eMonsterToad].move_power[1] = 8;
      _monster_db[eMonsterToad].move_mp_cost[1] = 0;
      _monster_db[eMonsterToad].move_category[1] = eMoveSpecialAttack;
      _monster_db[eMonsterToad].move_status[1] = eCharStatusPoison;
      _monster_db[eMonsterToad].move_status_chance[1] = 100;
      _monster_db[eMonsterToad].move_status_duration[1] = 3;
      _monster_db[eMonsterToad].move_status_power[1] = 2;

      // 3: Magic Attack - MP
      _monster_db[eMonsterToad].move_names[2] = "Toad Spit";
      _monster_db[eMonsterToad].move_power[2] = 5;
      _monster_db[eMonsterToad].move_mp_cost[2] = 2;
      _monster_db[eMonsterToad].move_category[2] = eMoveOffensiveMagic;

      // 4: Magic Healing - MP
      _monster_db[eMonsterToad].move_names[3] = "Healing Croak";
      _monster_db[eMonsterToad].move_power[3] = 5;
      _monster_db[eMonsterToad].move_mp_cost[3] = 2;
      _monster_db[eMonsterToad].move_category[3] = eMoveHealingMagic;
      break;
  }
}

// ====================================================================================

void Combat_ClearStatusOnTarget(CharSheet* target, int status) {
  if (target == null) return;
  if (status < 0 || status >= CHAR_STATUS_COUNT) return;

  target.status_active[status] = false;
  target.status_duration[status] = 0;
  target.status_power[status] = 0;
}

int Combat_ApplyStatusToTarget(CharSheet* target, int status, int duration, int power) {
  if (target == null) return 0;
  if (status < 0 || status >= CHAR_STATUS_COUNT) return 0;

  if (duration < 1) duration = 1;
  if (power < 1) power = 1;

  bool was_active = false;

  was_active = target.status_active[status];
  target.status_active[status] = true;
  target.status_duration[status] = ClampInt(duration, target.status_duration[status], 99);
  target.status_power[status] = ClampInt(power, target.status_power[status], 999);

  if (was_active) return 2;
  return 1;
}

String Combat_ApplyTurnStartStatuses(CharSheet* target, String target_name) {
  if (target == null) return "";

  String log = "";
  int i = 0;

  while (i < CHAR_STATUS_COUNT) {
    if (target.status_active[i]) {
      int duration = target.status_duration[i];
      int power = target.status_power[i];

      if (i == eCharStatusPoison || i == eCharStatusBurn) {
        int dot_damage = power;
        if (dot_damage < 1) dot_damage = 1;

        Stat_ModHP(-dot_damage, target);

        String tick_msg = "";
        if (i == eCharStatusPoison) {
          tick_msg = String.Format("%s suffers %d poison damage.", target_name, dot_damage);
        }
        else {
          tick_msg = String.Format("%s suffers %d burn damage.", target_name, dot_damage);
        }

        if (log == "") {
          log = tick_msg;
        }
        else {
          log = String.Format("%s %s", log, tick_msg);
        }
      }
      else if (i == eCharStatusRegen) {
        int regen_amount = power;
        if (regen_amount < 1) regen_amount = 1;

        Stat_ModHP(regen_amount, target);

        String regen_msg = String.Format("%s recovers %d HP from regen.", target_name, regen_amount);
        if (log == "") {
          log = regen_msg;
        }
        else {
          log = String.Format("%s %s", log, regen_msg);
        }
      }

      duration--;
      if (duration <= 0) {
        Combat_ClearStatusOnTarget(target, i);

        String fade_msg = String.Format("%s fades.", GetStatusName(i));
        if (log == "") {
          log = fade_msg;
        }
        else {
          log = String.Format("%s %s", log, fade_msg);
        }
      }
      else {
        target.status_duration[i] = duration;
      }
    }

    i++;
  }

  return log;
}

String Combat_CombineTurnLog(String status_log, String action_log) {
  if (status_log == "") return action_log;
  return String.Format("%s %s", status_log, action_log);
}

void Combat_SetMeleeMove(int slot, String name, int power) {
  if (slot < 0 || slot >= 5) return;
  gCombat.melee_names[slot] = name;
  gCombat.melee_power[slot] = power;
}

void Combat_SetSpellMove(int slot, int spell_id, String name, int power, int mp_cost) {
  if (slot < 0 || slot >= 5) return;
  gCombat.spell_id[slot] = spell_id;
  gCombat.spell_names[slot] = name;
  gCombat.spell_power[slot] = power;
  gCombat.spell_mp_cost[slot] = mp_cost;
}

void Combat_ClearSpellMoves(){
  int i = 0;
  while (i < 5){
    gCombat.spell_id[i] = -1;
    gCombat.spell_names[i] = "";
    gCombat.spell_power[i] = 0;
    gCombat.spell_mp_cost[i] = 0;
    i++;
  }
}

void Combat_SyncPlayerSpellsFromSheet(){
  Combat_ClearSpellMoves();

  gCombat.known_spell_count = 0;
  gCombat.selected_spell = 0;

  if (gHeroStats == null) return;

  int i = 0;
  while (i < gHeroStats.known_spell_count){
    int spell_id = gHeroStats.known_spells[i];

    if (spell_id >= 0 && spell_id < SPELL_COUNT){
      if (SpellDB_IsUsable(spell_id, true)){
        if (gCombat.known_spell_count < 5){
          int slot = gCombat.known_spell_count;
          int skill = gHeroStats.spell_skill[spell_id];
          Combat_SetSpellMove(
            slot,
            spell_id,
            SpellDB_GetName(spell_id),
            SpellDB_GetPower(spell_id, true, skill),
            SpellDB_GetMPCost(spell_id, true, skill)
          );
          gCombat.known_spell_count++;
        }
      }
    }

    i++;
  }
}

void Combat_LoadEnemyFromMonsterData(MonsterKind kind, CharSheet* enemy){
  int i = 0;
  MonsterData(kind);

  while (i < STAT_COUNT){
    enemy.base[i] = _monster_db[kind].base[i];
    enemy.temp[i] = 0;
    i++;
  }

  Stat_RecalcDerived(enemy);

  enemy.hp_max = _monster_db[kind].hp_max;
  enemy.mp_max = _monster_db[kind].mp_max;
  enemy.hp = enemy.hp_max;
  enemy.mp = enemy.mp_max;
  Stat_ClearStatuses(enemy);
}

void Combat_RegisterStarterMelee() {
  gCombat.known_melee_count = 1;
  gCombat.selected_melee = 0;
  Combat_SetMeleeMove(0, "Strike", 6);
}

void Combat_Init() {
  gCombat.active = false;
  gCombat.state = eCombatInactive;
  gCombat.atb_max = 100;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;
  gCombat.enemy_persistent = false;
  Combat_RegisterStarterMelee();
  Combat_SyncPlayerSpellsFromSheet();
}

bool Combat_IsActive() {
  return gCombat.active;
}

bool Combat_PlayerHasHealingPotion() {
  return (player.InventoryQuantity[iHealingPotion.ID] > 0);
}

void Combat_SetInitialATBFromAgility() {
  int player_agi = Stat_GetEffective(eStatAgility, gHeroStats);
  int enemy_agi = Stat_GetEffective(eStatAgility, gCombat.enemy);

  // A fair prefill centered around 50 with agility influence and a small random swing.
  int agility_swing = ClampInt((player_agi - enemy_agi) * 3, -35, 35);
  int player_random = Random(20) - 10; // -10..10
  int enemy_random = Random(20) - 10;  // -10..10

  gCombat.player_atb = ClampInt(50 + agility_swing + player_random, 0, gCombat.atb_max);
  gCombat.enemy_atb = ClampInt(50 - agility_swing + enemy_random, 0, gCombat.atb_max);
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;
}

void Combat_StartByKind(MonsterKind kind) {
  if (!gStatsReady) return;
  if (gCombat.enemy == null) {
    gCombat.enemy = new CharSheet;
  }

  bool resume_existing_enemy = false;

  MonsterData(kind);
  if (gCombat.enemy_persistent) {
    if (gCombat.enemy_kind == kind && gCombat.enemy.hp > 0) {
      resume_existing_enemy = true;
    }
  }

  // Disable GUI Icon Bar and Force Pointer Mode
  CursorDisableMouseModes();
  CursorForcePointerMode();
  gIconbar.Visible = false;

  // Show Combat GUI
  guiCombat.Visible = true;
  guiCombatLog.Visible = true;
  guiCombatPlayerStatus.Visible = true;
  guiCombatEnemyStatus.Visible = true;

  // Load Monster Data
  gCombat.enemy_kind = kind;
  Combat_SyncPlayerSpellsFromSheet();
  if (!resume_existing_enemy) {
    Combat_LoadEnemyFromMonsterData(kind, gCombat.enemy);
    gCombat.enemy_persistent = true;
  }

  // Play Battle Music
  Music_Play(aBattle, true); // need to make this contextual to the enemy

  // ATBs
  gCombat.player_atb = 0;
  gCombat.enemy_atb = 0;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;
  gCombat.player_defending = false;
  gCombat.enemy_defending = false;

  if (resume_existing_enemy) {
    lblCombatLog.Text = String.Format("Battle resumed against %s.", _monster_db[kind].name);
  }
  else {
    lblCombatLog.Text = String.Format("Battle started! A %s appears.", _monster_db[kind].name);
  }

  gCombat.active = true;
  gCombat.state = eCombatRunning;

  Combat_SetInitialATBFromAgility();
}

void Combat_ClearEnemyState()
{
  int i = 0;

  if (gCombat.enemy == null) return;

  while (i < STAT_COUNT)
  {
    gCombat.enemy.base[i] = 0;
    gCombat.enemy.temp[i] = 0;
    i++;
  }

  gCombat.enemy.hp = 0;
  gCombat.enemy.hp_max = 0;
  gCombat.enemy.mp = 0;
  gCombat.enemy.mp_max = 0;
  Stat_ClearStatuses(gCombat.enemy);
}

void Combat_End() {
  CombatState ended_state = gCombat.state;

  // Hide Combat GUI
  guiCombat.Visible = false;
  guiCombatLog.Visible = false;
  guiCombatPlayerStatus.Visible = false;
  guiCombatEnemyStatus.Visible = false;

  if (ended_state == eCombatVictory || ended_state == eCombatEscaped){
    // Re-enable GUI Icon Bar and Mouse Modes
    CursorEnableMouseModes();
    CursorReturnPrevious();
    gIconbar.Visible = true;
    // Return to the previous music - in the case of GameOver this will be instantly overridden
    Music_PlayPrevious();

    if (ended_state == eCombatVictory){
      // Display the victory message
      Display(_monster_db[gCombat.enemy_kind].victory);
    }
    else {
      Display("You escaped successfully.");
    }
  } else {
    GameOverGui_Open(_monster_db[gCombat.enemy_kind].death);
  }

  // End Combat
  gCombat.active = false;
  gCombat.state = eCombatInactive;

  // Data Clean Up
  if (ended_state == eCombatEscaped) {
    gCombat.enemy_persistent = true;
  }
  else {
    Combat_ClearEnemyState();
    gCombat.enemy_persistent = false;
  }
  gCombat.player_atb = 0;
  gCombat.enemy_atb = 0;
  gCombat.player_atb_accum_x100 = 0;
  gCombat.enemy_atb_accum_x100 = 0;

  gCombat.player_defending = false;
  gCombat.enemy_defending = false;

  lblCombatLog.Text = "";
}

void Combat_CheckEndConditions() {
  // Victory
  if (gCombat.enemy.hp <= 0) {
    gCombat.enemy.hp = 0;
    gCombat.state = eCombatVictory;
    Combat_End();
    return;
  }

  // Defeat
  if (gHeroStats.hp <= 0) {
    gHeroStats.hp = 0;
    gCombat.state = eCombatDefeat;
    Combat_End();
    return;
  }
}

int Combat_BehaviourClamp(int value){
  return ClampInt(value, 0, 10);
}

int Combat_BehaviourWeight(int value){
  value = Combat_BehaviourClamp(value);
  return value * value;
}

int Combat_EnemyDamageBasic() {
  int atk = Stat_GetEffective(eStatStrength, gCombat.enemy);
  int dmg = atk + 4;
  if (dmg < 1) dmg = 1;
  if (gCombat.player_defending) dmg = dmg / 2;
  return dmg;
}

void Combat_PlayerAttack() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblCombatLog.Text = "ATB not full yet.";
    return;
  }

  String status_log = Combat_ApplyTurnStartStatuses(gHeroStats, "You");
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  int basePower = gCombat.melee_power[gCombat.selected_melee];
  String moveName = gCombat.melee_names[gCombat.selected_melee];
  int dmg = Stat_GetEffective(eStatStrength, gHeroStats) + basePower;
  if (dmg < 1) dmg = 1;
  if (gCombat.enemy_defending) dmg = dmg / 2;

  Stat_ModHP(-dmg, gCombat.enemy);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  String action_log = String.Format("You use %s for %d damage.", moveName, dmg);
  lblCombatLog.Text = Combat_CombineTurnLog(status_log, action_log);
  Combat_CheckEndConditions();
}

void Combat_PlayerDefend() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblCombatLog.Text = "ATB not full yet.";
    return;
  }

  String status_log = Combat_ApplyTurnStartStatuses(gHeroStats, "You");
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  gCombat.player_defending = true;
  gCombat.player_atb = 0;
  lblCombatLog.Text = Combat_CombineTurnLog(status_log, "You brace for impact.");
}

void Combat_PlayerCast() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblCombatLog.Text = "ATB not full yet.";
    return;
  }

  String status_log = Combat_ApplyTurnStartStatuses(gHeroStats, "You");
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  if (gCombat.known_spell_count <= 0) {
    lblCombatLog.Text = Combat_CombineTurnLog(status_log, "No battle spells available.");
    return;
  }

  if (gCombat.selected_spell < 0 || gCombat.selected_spell >= gCombat.known_spell_count){
    gCombat.selected_spell = 0;
  }

  int spellId = gCombat.spell_id[gCombat.selected_spell];
  int spellCost = gCombat.spell_mp_cost[gCombat.selected_spell];
  int spellPower = gCombat.spell_power[gCombat.selected_spell];
  String spellName = gCombat.spell_names[gCombat.selected_spell];

  if (gHeroStats.mp < spellCost) {
    lblCombatLog.Text = "Not enough MP.";
    return;
  }

  Stat_ModMP(-spellCost, gHeroStats);

  int intstat = Stat_GetEffective(eStatIntelligence, gHeroStats);
  int dmg = intstat + spellPower;
  if (gCombat.enemy_defending) dmg = dmg / 2;
  if (dmg < 1) dmg = 1;

  Stat_ModHP(-dmg, gCombat.enemy);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  Stat_GrantSpellSkillXP(spellId, 1, gHeroStats);
  Combat_SyncPlayerSpellsFromSheet();

  String action_log = String.Format("You cast %s for %d damage.", spellName, dmg);
  lblCombatLog.Text = Combat_CombineTurnLog(status_log, action_log);
  Combat_CheckEndConditions();
}

void Combat_PlayerPotion() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblCombatLog.Text = "ATB not full yet.";
    return;
  }

  String status_log = Combat_ApplyTurnStartStatuses(gHeroStats, "You");
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  if (!Combat_PlayerHasHealingPotion()) {
    lblCombatLog.Text = Combat_CombineTurnLog(status_log, "No Healing Potions left.");
    return;
  }

  // Call your existing inventory script function.
  iHealingPotion_Drink();

  gCombat.player_atb = 0;
  gCombat.player_defending = false;
  lblCombatLog.Text = Combat_CombineTurnLog(status_log, "You drink a Healing Potion.");
}

void Combat_PlayerRun() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) {
    lblCombatLog.Text = "ATB not full yet.";
    return;
  }

  String status_log = Combat_ApplyTurnStartStatuses(gHeroStats, "You");
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  int player_agi = Stat_GetEffective(eStatAgility, gHeroStats);
  int enemy_agi = Stat_GetEffective(eStatAgility, gCombat.enemy);
  int chance = 35 + ((player_agi - enemy_agi) * 4);
  chance = ClampInt(chance, 10, 90);

  int roll = Random(99) + 1;
  if (roll <= chance) {
    gCombat.state = eCombatEscaped;
    Combat_End();
    return;
  }

  gCombat.player_atb = 0;
  gCombat.player_defending = false;
  lblCombatLog.Text = Combat_CombineTurnLog(status_log, "You try to run, but fail.");
}

int Combat_GetEnemyDefendWeight()
{
  int weight = Combat_BehaviourWeight(_monster_db[gCombat.enemy_kind].defensiveness);

  if (gCombat.enemy.hp <= (gCombat.enemy.hp_max / 3))
  {
    weight = weight + 10;
  }

  return weight;
}

int Combat_GetEnemyMoveWeight(int move_index)
{
  MonsterKind kind = gCombat.enemy_kind;
  EnemyMoveCategory category = _monster_db[kind].move_category[move_index];
  int mp_cost = _monster_db[kind].move_mp_cost[move_index];

  // Cannot use moves the monster cannot afford
  if (gCombat.enemy.mp < mp_cost)
  {
    return 0;
  }

  switch (category)
  {
    case eMoveNormalAttack:
      return Combat_BehaviourWeight(_monster_db[kind].aggression);

    case eMoveSpecialAttack:
      return Combat_BehaviourWeight(_monster_db[kind].specialAttack);

    case eMoveOffensiveMagic:
      return Combat_BehaviourWeight(_monster_db[kind].magicUse);

    case eMoveHealingMagic:
      if (gCombat.enemy.hp >= (gCombat.enemy.hp_max / 2))
      {
        return 0;
      }

      return Combat_BehaviourWeight(_monster_db[kind].magicUse);
  }

  return 0;
}

int Combat_FindEnemyFallbackMove()
{
  int i = 0;
  MonsterKind kind = gCombat.enemy_kind;

  // First prefer any usable normal attack
  while (i < _monster_db[kind].move_count)
  {
    if (_monster_db[kind].move_category[i] == eMoveNormalAttack)
    {
      if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
      {
        return i;
      }
    }

    i++;
  }

  i = 0;

  // Then prefer any usable special attack
  while (i < _monster_db[kind].move_count)
  {
    if (_monster_db[kind].move_category[i] == eMoveSpecialAttack)
    {
      if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
      {
        return i;
      }
    }

    i++;
  }

  i = 0;

  // Then any other usable move
  while (i < _monster_db[kind].move_count)
  {
    if (gCombat.enemy.mp >= _monster_db[kind].move_mp_cost[i])
    {
      return i;
    }

    i++;
  }

  return -1;
}

int Combat_ChooseEnemyAction()
{
  int total_weight = 0;
  int move_weights[5];
  int i = 0;

  while (i < 5)
  {
    move_weights[i] = 0;
    i++;
  }

  i = 0;
  while (i < _monster_db[gCombat.enemy_kind].move_count)
  {
    move_weights[i] = Combat_GetEnemyMoveWeight(i);
    total_weight = total_weight + move_weights[i];
    i++;
  }

  int defend_weight = Combat_GetEnemyDefendWeight();
  total_weight = total_weight + defend_weight;

  if (total_weight <= 0)
  {
    return -1;
  }

  int roll = Random(total_weight - 1);

  i = 0;
  while (i < _monster_db[gCombat.enemy_kind].move_count)
  {
    if (roll < move_weights[i])
    {
      return i;
    }

    roll = roll - move_weights[i];
    i++;
  }

  if (roll < defend_weight)
  {
    return -2;
  }

  return -1;
}

void Combat_EnemyUseMove(int move_index)
{
  MonsterKind kind = gCombat.enemy_kind;
  String enemyName = _monster_db[kind].name;
  String move_name = _monster_db[kind].move_names[move_index];
  int move_power = _monster_db[kind].move_power[move_index];
  int move_mp_cost = _monster_db[kind].move_mp_cost[move_index];
  EnemyMoveCategory category = _monster_db[kind].move_category[move_index];
  int move_status = _monster_db[kind].move_status[move_index];
  int move_status_chance = _monster_db[kind].move_status_chance[move_index];
  int move_status_duration = _monster_db[kind].move_status_duration[move_index];
  int move_status_power = _monster_db[kind].move_status_power[move_index];

  if (gCombat.enemy.mp < move_mp_cost)
  {
    gCombat.enemy_defending = true;
    gCombat.enemy_atb = 0;
    lblCombatLog.Text = String.Format("%s tries to use %s, but lacks the MP and defends.", enemyName, move_name);
    Combat_CheckEndConditions();
    return;
  }

  Stat_ModMP(-move_mp_cost, gCombat.enemy);

  if (category == eMoveHealingMagic)
  {
    int heal = Stat_GetEffective(eStatIntelligence, gCombat.enemy) + move_power;

    if (heal < 1) heal = 1;

    Stat_ModHP(heal, gCombat.enemy);
    gCombat.enemy_defending = false;
    gCombat.enemy_atb = 0;

    lblCombatLog.Text = String.Format("%s uses %s and recovers %d HP.", enemyName, move_name, heal);
    Combat_CheckEndConditions();
    return;
  }

  int dmg = 0;

  if (category == eMoveOffensiveMagic)
  {
    dmg = Stat_GetEffective(eStatIntelligence, gCombat.enemy) + move_power;
  }
  else
  {
    dmg = Stat_GetEffective(eStatStrength, gCombat.enemy) + move_power;
  }

  if (dmg < 1) dmg = 1;
  if (gCombat.player_defending) dmg = dmg / 2;

  Stat_ModHP(-dmg, gHeroStats);

  gCombat.enemy_defending = false;
  gCombat.enemy_atb = 0;

  String action_log = String.Format("%s uses %s for %d damage.", enemyName, move_name, dmg);

  if (move_status >= 0 && move_status < CHAR_STATUS_COUNT && move_status_chance > 0)
  {
    int roll = Random(99) + 1;
    if (roll <= move_status_chance)
    {
      int apply_result = Combat_ApplyStatusToTarget(gHeroStats, move_status, move_status_duration, move_status_power);
      if (apply_result == 1)
      {
        action_log = String.Format("%s You are afflicted with %s.", action_log, GetStatusName(move_status));
      }
      else if (apply_result == 2)
      {
        action_log = String.Format("%s Your %s worsens.", action_log, GetStatusName(move_status));
      }
    }
  }

  lblCombatLog.Text = action_log;

  Combat_CheckEndConditions();
}

void Combat_EnemyTurn()
{
  if (!Combat_IsActive()) return;
  if (gCombat.enemy_atb < gCombat.atb_max) return;

  String status_log = Combat_ApplyTurnStartStatuses(gCombat.enemy, _monster_db[gCombat.enemy_kind].name);
  Combat_CheckEndConditions();
  if (!Combat_IsActive()) return;

  String enemyName = _monster_db[gCombat.enemy_kind].name;
  int action = Combat_ChooseEnemyAction();

  if (action < 0)
  {
    if (action == -2)
    {
      gCombat.enemy_defending = true;
      gCombat.enemy_atb = 0;
      lblCombatLog.Text = Combat_CombineTurnLog(status_log, String.Format("%s defends.", enemyName));
      Combat_CheckEndConditions();
      return;
    }

    action = Combat_FindEnemyFallbackMove();
  }

  if (action < 0)
  {
    gCombat.enemy_defending = true;
    gCombat.enemy_atb = 0;
    lblCombatLog.Text = Combat_CombineTurnLog(status_log, String.Format("%s defends.", enemyName));
    Combat_CheckEndConditions();
    return;
  }

  Combat_EnemyUseMove(action);
  if (status_log != "" && Combat_IsActive())
  {
    lblCombatLog.Text = Combat_CombineTurnLog(status_log, lblCombatLog.Text);
  }
}

void Combat_SetPlayerCommandButtonsEnabled(bool enabled) {
  bool hasPotion = Combat_PlayerHasHealingPotion();
  bool hasBattleSpell = (gCombat.known_spell_count > 0);

  btnAttack.Enabled = enabled;
  btnDefend.Enabled = enabled;
  btnRun.Enabled = enabled;
  btnSpell.Enabled = (enabled && hasBattleSpell);

  // Potion button follows both ATB readiness and inventory quantity
  btnPotion.Enabled = (enabled && hasPotion);
}

void Combat_UpdateHUD() {
  if (!Combat_IsActive()) return;
  
  // Player Status
  // HP
  lblCombatPlayerName.Text = gHeroName;
  lblCombatPlayerHP.Text = String.Format("%d", gHeroStats.hp);
  
  // HP Bar and text color when poisoned
  if (gHeroStats.status_active[eCharStatusPoison]) {
    // Poisoned
    lblCombatPlayerHP.TextColor = 32320;
    btnCombatPlayerHPBar.NormalGraphic = 166;
  }
  else {
    // Normal
    lblCombatPlayerHP.TextColor = 65535;
    btnCombatPlayerHPBar.NormalGraphic = 164;
  }
  UpdateBar(btnCombatPlayerHPBar, gHeroStats.hp, gHeroStats.hp_max, 58); // Update player HP Bar

  //MP
  lblCombatPlayerMP.Text = String.Format("%d", gHeroStats.mp);
  UpdateBar(btnCombatPlayerMPBar, gHeroStats.mp, gHeroStats.mp_max, 58); // Update player MP Bar

  //ATB
  sldCombatPlayerATB.Max = gCombat.atb_max;
  sldCombatPlayerATB.Value = gCombat.player_atb;
  
  // Enemy Status
  lblCombatEnemyName.Text = _monster_db[gCombat.enemy_kind].name;
  lblCombatEnemyHP.Text = String.Format("%d", gCombat.enemy.hp);
  // HP Bar and text color when poisoned
  if (gCombat.enemy.status_active[eCharStatusPoison]) {
    // Poisoned
    lblCombatEnemyHP.TextColor = 32320;
    btnCombatEnemyHPBar.NormalGraphic = 166;
  }
  else {
    // Normal
    lblCombatEnemyHP.TextColor = 65535;
    btnCombatEnemyHPBar.NormalGraphic = 164;
  }
  UpdateBar(btnCombatEnemyHPBar, gCombat.enemy.hp, gCombat.enemy.hp_max, 58); // Update enemy HP Bar

  sldCombatEnemyATB.Max = gCombat.atb_max;
  sldCombatEnemyATB.Value = gCombat.enemy_atb;

  if (gCombat.player_atb >= gCombat.atb_max) {
    Combat_SetPlayerCommandButtonsEnabled(true);
  }
  else {
    Combat_SetPlayerCommandButtonsEnabled(false);
  }
}


int Combat_ATBPointsPerSecondFromAgility(int agi) {
  // target scaling:
  // agility 3  -> 5.0s to fill (20 points/sec for atb_max=100)
  // agility 50 -> 1.0s to fill (100 points/sec)
  int a = ClampInt(agi, 3, 50);
  int pps = 20 + ((a - 3) * 80) / 47;
  return pps;
}

int Combat_GetATBSpeedDivisor() {
  int speed = sldSpeed.Value;
  if (speed < 1) speed = 1;
  return speed;
}

void Combat_ATBAdvancePlayerOneCycle() {
  int pps = Combat_ATBPointsPerSecondFromAgility(Stat_GetEffective(eStatAgility, gHeroStats));

  // fixed-point x100 so low speeds stay smooth on integer cycles
  int add_x100 = (pps * 100) / Combat_GetATBSpeedDivisor();
  gCombat.player_atb_accum_x100 = gCombat.player_atb_accum_x100 + add_x100;

  int whole = gCombat.player_atb_accum_x100 / 100;
  gCombat.player_atb_accum_x100 = gCombat.player_atb_accum_x100 % 100;

  gCombat.player_atb = ClampInt(gCombat.player_atb + whole, 0, gCombat.atb_max);
}

void Combat_ATBAdvanceEnemyOneCycle() {
  int pps = Combat_ATBPointsPerSecondFromAgility(Stat_GetEffective(eStatAgility, gCombat.enemy));

  int add_x100 = (pps * 100) / Combat_GetATBSpeedDivisor();
  gCombat.enemy_atb_accum_x100 = gCombat.enemy_atb_accum_x100 + add_x100;

  int whole = gCombat.enemy_atb_accum_x100 / 100;
  gCombat.enemy_atb_accum_x100 = gCombat.enemy_atb_accum_x100 % 100;

  gCombat.enemy_atb = ClampInt(gCombat.enemy_atb + whole, 0, gCombat.atb_max);
}

void Combat_Update() {
  if (!Combat_IsActive()) return;

  Combat_ATBAdvancePlayerOneCycle();
  Combat_ATBAdvanceEnemyOneCycle();

  Combat_EnemyTurn();
  Combat_UpdateHUD();
}

