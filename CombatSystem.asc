// ==========================================
// CombatSystem.asc (SCRIPT)
// ==========================================

CombatRuntime gCombat;

#define MAX_POTIONS 10
InventoryItem* _potion_items[MAX_POTIONS];
int _potion_heal_hp[MAX_POTIONS];
int _potion_restore_mp[MAX_POTIONS];
int _potion_count = 0;

MonsterTemplate _monster_db[eMonsterCount];

int ClampInt(int value, int minv, int maxv) {
  if (value < minv) return minv;
  if (value > maxv) return maxv;
  return value;
}

void Combat_SetMeleeMove(int slot, String name, int power) {
  if (slot < 0 || slot >= 5) return;
  gCombat.melee_names[slot] = name;
  gCombat.melee_power[slot] = power;
}

void Combat_SetSpellMove(int slot, String name, int power, int mp_cost) {
  if (slot < 0 || slot >= 5) return;
  gCombat.spell_names[slot] = name;
  gCombat.spell_power[slot] = power;
  gCombat.spell_mp_cost[slot] = mp_cost;
}

void Combat_FillGoblinTemplate() {
  _monster_db[eMonsterGoblin].name = "Goblin";
  _monster_db[eMonsterGoblin].kind = eMonsterGoblin;
  _monster_db[eMonsterGoblin].level = 1;

  _monster_db[eMonsterGoblin].base[eStatStrength] = 5;
  _monster_db[eMonsterGoblin].base[eStatVitality] = 5;
  _monster_db[eMonsterGoblin].base[eStatIntelligence] = 2;
  _monster_db[eMonsterGoblin].base[eStatAgility] = 5;
  _monster_db[eMonsterGoblin].base[eStatKinesthesia] = 3;
  _monster_db[eMonsterGoblin].base[eStatCommunication] = 1;

  _monster_db[eMonsterGoblin].hp_max = 24;
  _monster_db[eMonsterGoblin].mp_max = 4;
  _monster_db[eMonsterGoblin].atb_speed = 3;
}

void Combat_InitMonsterDB() {
  Combat_FillGoblinTemplate();
}

void Combat_ApplyTemplateToEnemy(MonsterKind kind, CharSheet* enemy) {
  int i = 0;
  while (i < STAT_COUNT) {
    enemy.base[i] = _monster_db[kind].base[i];
    enemy.temp[i] = 0;
    i++;
  }

  Stat_RecalcDerived(enemy);
  enemy.hp_max = _monster_db[kind].hp_max;
  enemy.mp_max = _monster_db[kind].mp_max;
  enemy.hp = enemy.hp_max;
  enemy.mp = enemy.mp_max;
}

void Combat_RegisterStarterMoves() {
  gCombat.known_melee_count = 1;
  gCombat.selected_melee = 0;
  Combat_SetMeleeMove(0, "Strike", 6);

  gCombat.known_spell_count = 1;
  gCombat.selected_spell = 0;
  Combat_SetSpellMove(0, "Spark", 8, 2);
}

void Combat_Init() {
  gCombat.active = false;
  gCombat.state = eCombatInactive;
  gCombat.atb_max = 100;

  Combat_InitMonsterDB();
  Combat_RegisterStarterMoves();
}

bool Combat_IsActive() {
  return gCombat.active;
}

void Combat_RegisterPotion(InventoryItem* item, int heal_hp, int restore_mp) {
  if (item == null) return;
  if (_potion_count >= MAX_POTIONS) return;

  _potion_items[_potion_count] = item;
  _potion_heal_hp[_potion_count] = heal_hp;
  _potion_restore_mp[_potion_count] = restore_mp;
  _potion_count++;
}

void Combat_StartByKind(MonsterKind kind) {
  if (!gStatsReady) return;
  if (gCombat.enemy == null) {
    gCombat.enemy = new CharSheet;
  }

  aVision.Play();
  
  gCombat.enemy_kind = kind;
  Combat_ApplyTemplateToEnemy(kind, gCombat.enemy);

  gCombat.player_atb = 0;
  gCombat.enemy_atb = 0;
  gCombat.player_defending = false;
  gCombat.enemy_defending = false;

  gCombat.active = true;
  gCombat.state = eCombatRunning;

  // show GUI layer now
  guiBattle.Visible = true;
}

void Combat_End() {
  gCombat.active = false;
  gCombat.state = eCombatInactive;
  guiBattle.Visible = false;
}

int Combat_EnemyDamageBasic() {
  int atk = Stat_GetEffective(eStatStrength, gCombat.enemy);
  int dmg = atk + 4;
  if (dmg < 1) dmg = 1;
  if (gCombat.player_defending) dmg = dmg / 2;
  return dmg;
}

void Combat_CheckEndConditions() {
  if (gCombat.enemy.hp <= 0) {
    gCombat.enemy.hp = 0;
    gCombat.state = eCombatVictory;
    Combat_End();
    return;
  }

  if (gHeroStats.hp <= 0) {
    gHeroStats.hp = 0;
    gCombat.state = eCombatDefeat;
    Combat_End();
    return;
  }
}

void Combat_PlayerAttack() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) return;

  int basePower = gCombat.melee_power[gCombat.selected_melee];
  String moveName = gCombat.melee_names[gCombat.selected_melee];
  int dmg = Stat_GetEffective(eStatStrength, gHeroStats) + basePower;
  if (dmg < 1) dmg = 1;
  if (gCombat.enemy_defending) dmg = dmg / 2;

  gCombat.enemy.hp = ClampInt(gCombat.enemy.hp - dmg, 0, gCombat.enemy.hp_max);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  lblBattleLog.Text = String.Format("You use %s for %d damage.", moveName, dmg);
  Combat_CheckEndConditions();
}

void Combat_PlayerDefend() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) return;

  gCombat.player_defending = true;
  gCombat.player_atb = 0;
  lblBattleLog.Text = "You brace for impact.";
}

void Combat_PlayerCast() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) return;

  int spellCost = gCombat.spell_mp_cost[gCombat.selected_spell];
  int spellPower = gCombat.spell_power[gCombat.selected_spell];
  String spellName = gCombat.spell_names[gCombat.selected_spell];

  if (gHeroStats.mp < spellCost) {
    lblBattleLog.Text = "Not enough MP.";
    return;
  }

  Stat_ModMP(-spellCost, gHeroStats);

  int intstat = Stat_GetEffective(eStatIntelligence, gHeroStats);
  int dmg = intstat + spellPower;
  if (gCombat.enemy_defending) dmg = dmg / 2;
  if (dmg < 1) dmg = 1;

  gCombat.enemy.hp = ClampInt(gCombat.enemy.hp - dmg, 0, gCombat.enemy.hp_max);
  gCombat.player_atb = 0;
  gCombat.player_defending = false;

  lblBattleLog.Text = String.Format("You cast %s for %d damage.", spellName, dmg);
  Combat_CheckEndConditions();
}

void Combat_PlayerPotion() {
  if (!Combat_IsActive()) return;
  if (gCombat.player_atb < gCombat.atb_max) return;

  int i = 0;
  while (i < _potion_count) {
    InventoryItem* item = _potion_items[i];
    if (player.InventoryQuantity[item.ID] > 0) {
      player.LoseInventory(item);
      Stat_ModHP(_potion_heal_hp[i], gHeroStats);
      Stat_ModMP(_potion_restore_mp[i], gHeroStats);
      gCombat.player_atb = 0;
      gCombat.player_defending = false;
      lblBattleLog.Text = String.Format("Used %s.", item.Name);
      return;
    }
    i++;
  }

  lblBattleLog.Text = "No usable potion.";
}

void Combat_EnemyTurn() {
  if (!Combat_IsActive()) return;
  if (gCombat.enemy_atb < gCombat.atb_max) return;

  int roll = Random(99);
  if (roll < 75) {
    int dmg = Combat_EnemyDamageBasic();
    Stat_ModHP(-dmg, gHeroStats);
    gCombat.enemy_defending = false;
    lblBattleLog.Text = String.Format("%s attacks for %d.", _monster_db[gCombat.enemy_kind].name, dmg);
  }
  else {
    gCombat.enemy_defending = true;
    lblBattleLog.Text = String.Format("%s defends.", _monster_db[gCombat.enemy_kind].name);
  }

  gCombat.enemy_atb = 0;
  Combat_CheckEndConditions();
}

void Combat_UpdateHUD() {
  if (!Combat_IsActive()) return;

  sldPlayerHP.Max = gHeroStats.hp_max;
  sldPlayerHP.Value = gHeroStats.hp;

  sldPlayerMP.Max = gHeroStats.mp_max;
  sldPlayerMP.Value = gHeroStats.mp;

  sldPlayerATB.Max = gCombat.atb_max;
  sldPlayerATB.Value = gCombat.player_atb;

  lblPlayerHP.Text = String.Format("HP %d/%d", gHeroStats.hp, gHeroStats.hp_max);
  lblPlayerMP.Text = String.Format("MP %d/%d", gHeroStats.mp, gHeroStats.mp_max);

  // Optional enemy HUD (only if those controls exist in your GUI):
  // sldEnemyHP.Max = gCombat.enemy.hp_max;
  // sldEnemyHP.Value = gCombat.enemy.hp;
  // sldEnemyMP.Max = gCombat.enemy.mp_max;
  // sldEnemyMP.Value = gCombat.enemy.mp;
  // sldEnemyATB.Max = gCombat.atb_max;
  // sldEnemyATB.Value = gCombat.enemy_atb;
  // lblEnemyHP.Text = String.Format("HP %d/%d", gCombat.enemy.hp, gCombat.enemy.hp_max);
  // lblEnemyMP.Text = String.Format("MP %d/%d", gCombat.enemy.mp, gCombat.enemy.mp_max);
}

void Combat_Update() {
  if (!Combat_IsActive()) return;

  // ATB fill (tune with game speed)
  int p_speed = Stat_GetEffective(eStatAgility, gHeroStats);
  int e_speed = Stat_GetEffective(eStatAgility, gCombat.enemy);

  gCombat.player_atb = ClampInt(gCombat.player_atb + p_speed, 0, gCombat.atb_max);
  gCombat.enemy_atb = ClampInt(gCombat.enemy_atb + e_speed, 0, gCombat.atb_max);

  Combat_EnemyTurn();
  Combat_UpdateHUD();
}

void Combat_SelectNextMelee() {
  if (gCombat.known_melee_count <= 0) return;
  gCombat.selected_melee++;
  if (gCombat.selected_melee >= gCombat.known_melee_count) gCombat.selected_melee = 0;
}

void Combat_SelectPrevMelee() {
  if (gCombat.known_melee_count <= 0) return;
  gCombat.selected_melee--;
  if (gCombat.selected_melee < 0) gCombat.selected_melee = gCombat.known_melee_count - 1;
}

void Combat_SelectNextSpell() {
  if (gCombat.known_spell_count <= 0) return;
  gCombat.selected_spell++;
  if (gCombat.selected_spell >= gCombat.known_spell_count) gCombat.selected_spell = 0;
}

void Combat_SelectPrevSpell() {
  if (gCombat.known_spell_count <= 0) return;
  gCombat.selected_spell--;
  if (gCombat.selected_spell < 0) gCombat.selected_spell = gCombat.known_spell_count - 1;
}

export gCombat;