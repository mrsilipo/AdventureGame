// ==========================================
// Stats.asc (SCRIPT)
// Version 1.001
// ==========================================
//
// Purpose:
// - Owns the RPG stats layer (base stats, temp modifiers, derived HP/MP, class templates).
// - Exposes a small, safe API so HP/MP and stats do not get corrupted by direct writes.
//
// Conventions:
// - Base stats live in _sheet.base[]
// - Temp modifiers live in _sheet.temp[] and are SUBTRACTED from base for effective value
// - Derived stats are hp_max/mp_max, calculated from Vitality/Intelligence
// - Clamp vitals anytime HP/MP or max values change
//
// Notes:
// - CharSheet has: base[], temp[], hp/mp/hp_max/mp_max, gold, and class_id
// - STAT_COUNT and CLASS_COUNT are compile-time constants from Stats.ash
//

// ==========================================
// Global State
// ==========================================

// True once gHeroStats (and class table is initialized).
bool gStatsReady = false;

// Flat class base table: CLASS_COUNT * STAT_COUNT entries.
// Indexing: (_class * STAT_COUNT) + _stat
int _class_base_stats[18]; // 3 classes * 6 stats = 18 ints

// Global hero's name
String gHeroName;

// Global character sheets (managed structs are pointers).
CharSheet* gHeroStats;
CharSheet* gMonsterStats[10];

// ==========================================
// Display Helpers
// ==========================================

// Convert a class enum into a UI-friendly word.
String Stat_GetClassWord(StatClass _class){
  switch (_class){
    case eClassFighter: return "Fighter";
    case eClassMage:    return "Mage";
    case eClassThief:   return "Thief";
  }

  return "Unknown";
}

// Convert a stat enum into a UI-friendly word.
String Stat_GetWord(Stats _stat){
  if (_stat < 0 || _stat >= STAT_COUNT){
    return "Unknown";
  }

  switch (_stat){
    case eStatStrength:      return "Strength";
    case eStatVitality:      return "Vitality";
    case eStatIntelligence:  return "Intelligence";
    case eStatAgility:       return "Agility";
    case eStatDexterity:     return "Dexterity";
    case eStatCommunication: return "Communication";
  }

  return "Unknown";
}

// ==========================================
// Stat Accessors
// ==========================================

String GetStatusName(int status) {
  switch (status) {
    case eCharStatusPoison:
      return "Poison";
    case eCharStatusBurn:
      return "Burn";
    case eCharStatusRegen:
      return "Regen";
  }

  return "Unknown";
}

// Read the raw base stat value (permanent).
int Stat_GetBase(Stats _stat, CharSheet* _sheet){
  return _sheet.base[_stat];
}

// Read the effective stat value (base minus temp modifier).
// Temp is treated as a penalty/buff bucket that is subtracted from base.
int Stat_GetEffective(Stats _stat, CharSheet* _sheet){
  int _v = _sheet.base[_stat] - _sheet.temp[_stat];
  if (_v < 0){
    _v = 0;
  }
  return _v;
}

// ==========================================
// Vitals Safety
// ==========================================

// Clamp current HP/MP into valid ranges.
// Call this after:
// - taking damage/healing
// - changing max HP/MP
// - loading a save (sanitizing old or external values)
void Stat_ClampVitals(CharSheet* _sheet){
  if (_sheet.hp < 0){
    _sheet.hp = 0;
  }
  if (_sheet.mp < 0){
    _sheet.mp = 0;
  }

  if (_sheet.hp > _sheet.hp_max){
    _sheet.hp = _sheet.hp_max;
  }
  if (_sheet.mp > _sheet.mp_max){
    _sheet.mp = _sheet.mp_max;
  }
}

// Add/subtract HP, then clamp.
void Stat_ModHP(int _delta, CharSheet* _sheet){
  _sheet.hp += _delta;
  Stat_ClampVitals(_sheet);
}

// Add/subtract MP, then clamp.
void Stat_ModMP(int _delta, CharSheet* _sheet){
  _sheet.mp += _delta;
  Stat_ClampVitals(_sheet);
}

// Set HP directly (use this instead of writing _sheet.hp = ...), then clamp.
void Stat_SetHP(int _value, CharSheet* _sheet){
  _sheet.hp = _value;
  Stat_ClampVitals(_sheet);
}

void Stat_SetMP(int _value, CharSheet* _sheet){
  _sheet.mp = _value;
  Stat_ClampVitals(_sheet);
}

void Stat_ClearStatuses(CharSheet* _sheet){
  if (_sheet == null){
    return;
  }

  int i = 0;
  while (i < CHAR_STATUS_COUNT){
    _sheet.status_active[i] = false;
    _sheet.status_duration[i] = 0;
    _sheet.status_power[i] = 0;
    i++;
  }
}

void Stat_ClearSpells(CharSheet* _sheet){
  if (_sheet == null){
    return;
  }

  int i = 0;
  while (i < SPELLBOOK_CAPACITY){
    _sheet.known_spells[i] = -1;
    i++;
  }

  _sheet.known_spell_count = 0;

  i = 0;
  while (i < SPELL_COUNT){
    _sheet.spell_skill[i] = 0;
    i++;
  }
}

bool Stat_HasSpell(SpellId spell_id, CharSheet* _sheet){
  if (_sheet == null) return false;
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return false;

  int i = 0;
  while (i < _sheet.known_spell_count){
    if (_sheet.known_spells[i] == spell_id){
      return true;
    }
    i++;
  }

  return false;
}

bool Stat_LearnSpell(SpellId spell_id, CharSheet* _sheet){
  if (_sheet == null) return false;
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return false;
  if (Stat_HasSpell(spell_id, _sheet)) return false;
  if (_sheet.known_spell_count >= SPELLBOOK_CAPACITY) return false;

  _sheet.known_spells[_sheet.known_spell_count] = spell_id;
  _sheet.known_spell_count++;
  return true;
}

bool Stat_GrantSpellSkillXP(SpellId spell_id, int amount, CharSheet* sheet){
  if (sheet == null) return false;
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return false;
  if (amount <= 0) return false;
  if (!Stat_HasSpell(spell_id, sheet)) return false;

  int next_value = sheet.spell_skill[spell_id] + amount;
  if (next_value > SPELL_SKILL_MAX_CAP){
    next_value = SPELL_SKILL_MAX_CAP;
  }

  sheet.spell_skill[spell_id] = next_value;
  return true;
}

// ==========================================
// Derived Stats
// ==========================================

// Recalculate derived stats (max HP and max MP) from base stats.
//
// Derived rules:
// - hp_max = 20 + Vitality * 3
// - mp_max = 10 + Intelligence * 2
//
// Side effects:
// - Clamps current HP/MP to the new maximums.
void Stat_RecalcDerived(CharSheet* _sheet){
  _sheet.hp_max = 20 + (_sheet.base[eStatVitality] * 3);
  _sheet.mp_max = 10 + (_sheet.base[eStatIntelligence] * 2);

  Stat_ClampVitals(_sheet);
}

// ==========================================
// Permanent Stat Changes
// ==========================================

// Modify a base stat by a given amount (permanent change).
//
// Use for:
// - leveling
// - permanent buffs/curses
// - equipment that permanently alters base stats
//
// Rules:
// - base stats are clamped to 0 (no negatives)
// - derived stats are recalculated automatically (HP/MP max)
//
// Parameters:
//   _stat  - which base stat to modify
//   _delta - amount to add (negative subtracts)
//   _sheet - target character sheet
void Stat_ModBase(Stats _stat, int _delta, CharSheet* _sheet){
  if (_sheet == null){
    return;
  }

  _sheet.base[_stat] += _delta;

  if (_sheet.base[_stat] < 0){
    _sheet.base[_stat] = 0;
  }

  Stat_RecalcDerived(_sheet);
}

// ==========================================
// Class Base Table
// ==========================================

// Fill the class base-stat lookup table.
//
// Layout in _class_base_stats:
// - Fighter: indices 0..5
// - Mage:    indices 6..11
// - Thief:   indices 12..17
//
// This is currently called from Room 2 StartNewGameAs();
void Stat_InitClassBaseTable(){
  // Fighter (class 0)
  _class_base_stats[0] = 12; // Strength
  _class_base_stats[1] = 11; // Vitality
  _class_base_stats[2] =  7; // Intelligence
  _class_base_stats[3] =  8; // Agility
  _class_base_stats[4] =  7; // Dexterity
  _class_base_stats[5] =  6; // Communication

  // Mage (class 1)
  _class_base_stats[6]  =  6; // Strength
  _class_base_stats[7]  =  7; // Vitality
  _class_base_stats[8]  = 13; // Intelligence
  _class_base_stats[9]  =  8; // Agility
  _class_base_stats[10] =  9; // Dexterity
  _class_base_stats[11] =  8; // Communication

  // Thief (class 2)
  _class_base_stats[12] =  8; // Strength
  _class_base_stats[13] =  8; // Vitality
  _class_base_stats[14] =  8; // Intelligence
  _class_base_stats[15] = 12; // Agility
  _class_base_stats[16] = 11; // Dexterity
  _class_base_stats[17] =  9; // Communication
}

// Read one base stat from the class template table.
int Stat_GetClassBase(StatClass _class, Stats _stat){
  if (_class < 0 || _class >= CLASS_COUNT){
    return 0;
  }
  if (_stat < 0 || _stat >= STAT_COUNT){
    return 0;
  }

  return _class_base_stats[(_class * STAT_COUNT) + _stat];
}

// Apply a class template to a character sheet.
// This overwrites base stats, clears temp stats, and resets HP/MP to max.
void Stat_ApplyBaseClass(StatClass _class, CharSheet* _sheet){
  if (_sheet == null){
    return;
  }

  _sheet.class_id = _class;

  int _i = 0;
  while (_i < STAT_COUNT){
    _sheet.base[_i] = Stat_GetClassBase(_class, _i);
    _sheet.temp[_i] = 0;
    _i++;
  }

  _sheet.gold = 0;
  Stat_ClearStatuses(_sheet);
  Stat_ClearSpells(_sheet);

  // Starter spells by class
  switch(_class){
    case eClassFighter :
      break;
    case eClassMage :
      Stat_LearnSpell(eSpellVindor, _sheet);
      Stat_LearnSpell(eSpellPloom, _sheet);
      Stat_LearnSpell(eSpellRah, _sheet);
      Stat_LearnSpell(eSpellHum, _sheet);
      break;
    case eClassThief :
      break;
  }
  
  Stat_RecalcDerived(_sheet);
  _sheet.hp = _sheet.hp_max;
  _sheet.mp = _sheet.mp_max;
}

// ==========================================
// Monsters
// ==========================================

// Initialise monster stats.
// For now, _kind is a placeholder for future monster templates.
void Stat_InitBaseMonsterStats(CharSheet* _sheet, int _kind){
  if (_sheet == null){
    return;
  }

  _sheet.base[eStatStrength]      = 6;
  _sheet.base[eStatVitality]      = 8;
  _sheet.base[eStatIntelligence]  = 3;
  _sheet.base[eStatAgility]       = 8;
  _sheet.base[eStatDexterity]   = 10;
  _sheet.base[eStatCommunication] = 0;

  int _i = 0;
  while (_i < STAT_COUNT){
    _sheet.temp[_i] = 0;
    _i++;
  }

  _sheet.gold = 0;
  Stat_ClearStatuses(_sheet);
  Stat_ClearSpells(_sheet);

  Stat_RecalcDerived(_sheet);
  _sheet.hp = _sheet.hp_max;
  _sheet.mp = _sheet.mp_max;
}

// ==========================================
// Debug UI Output
// ==========================================

// Build a text block for quickly displaying the character sheet.
String Stat_BuildText(CharSheet* _sheet){
  String _t = "";

  _t = _t.Append(String.Format("%s\n", gHeroName));
  _t = _t.Append(String.Format("Class: %s\n", Stat_GetClassWord(_sheet.class_id)));

  int _i = 0;
  while (_i < STAT_COUNT){
    Stats _s = _i;
    _t = _t.Append(String.Format("%s: %d\n", Stat_GetWord(_s), Stat_GetEffective(_s, _sheet)));
    _i++;
  }

  _t = _t.Append(String.Format("HP: %d/%d\n", _sheet.hp, _sheet.hp_max));
  _t = _t.Append(String.Format("MP: %d/%d\n", _sheet.mp, _sheet.mp_max));
  _t = _t.Append( TF2("GOLD.STATS.TOTAL", I(gHeroStats.gold), T("GOLD.CURRENCY")) );

  return _t;
}

// ==========================================
// Add Gold
// ==========================================
void AddGold(int _amount){
  if (!player.HasInventory(iCoinPouch)){
    player.AddInventory(iCoinPouch);
  }
  gHeroStats.gold += _amount;
  Display(TF2("GOLD.ADD.TOTAL", I(gHeroStats.gold), T("GOLD.CURRENCY")));
}

// ==========================================
// Exports
// ==========================================
export gStatsReady;
export gHeroName;
export gHeroStats;
export gMonsterStats;
