function oStick_Interact(Object *theObject, CursorMode mode)
{
	WalkToInteraction(125, 111, eDirectionUp, WAIT_DEFAULT);
  aSFX001.Play();
	oStick.Visible = false;
	VOICEOVER = aVO_VisionIdol_StickInteract.Play();
  Display(T("RM.VISION.IDOL.STICK.INTERACT"));
  VOICEOVER.Stop();
  player.AddInventory(iInvStick);
}

