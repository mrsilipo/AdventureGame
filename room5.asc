// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Idol

function hIdol_Look(Hotspot *theHotspot, CursorMode mode)
{
	VOICEOVER = aVO_VisionIdol_IdolLook.Play();
	Display(T("RM.VISION.IDOL.IDOL.LOOK"));
	VOICEOVER.Stop();
}

function hIdol_Interact(Hotspot *theHotspot, CursorMode mode)
{
	WalkToInteraction(146, 147, eDirectionUp, WAIT_DEFAULT);

	switch (_idol_interation){
	case 0:
    aSFX003.Play();
    Wait(100);
    oVisionDoor.SetView(3);
    VOICEOVER = aVO_VisionIdol_IdolInteract1.Play();
		Display(T("RM.VISION.IDOL.IDOL.INTERACT.1"));
    VOICEOVER.Stop();
    VOICEOVER = aVO_VisionIdol_IdolInteract2.Play();
		Display(T("RM.VISION.IDOL.IDOL.INTERACT.2"));
    VOICEOVER.Stop();
		_idol_interation ++;
		break;
	default:
    VOICEOVER = aVO_VisionIdol_IdolInteract3.Play();
		Display(T("RM.VISION.IDOL.IDOL.INTERACT.3"));
    VOICEOVER.Stop();
		break;
	}
}

