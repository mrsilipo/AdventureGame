// room script file

int _idol_interation = 0;

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

function room_Load()
{
  FadeIn(1);
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

function room_AfterFadeIn()
{
  // Intro
  Wait(20);
  VOICEOVER = aVO_VisionIdol_Intro1.Play();
  Display(T("RM.VISION.IDOL.INTRO.1"));
  VOICEOVER.Stop();
  VOICEOVER = aVO_VisionIdol_Intro2.Play();
  Display(T("RM.VISION.IDOL.INTRO.2"));
  VOICEOVER.Stop();
  VOICEOVER = aVO_VisionIdol_Intro3.Play();
  Display(T("RM.VISION.IDOL.INTRO.3"));
  VOICEOVER.Stop();

  // Change view to standing
  player.ChangeView(HERO_WALK);

  // Force pointer mode
  Mouse.UseModeGraphic(eModeLookat);
  Mouse.Mode = eModeLookat;
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
function hRoom_Look(Hotspot *theHotspot, CursorMode mode)
{
  VOICEOVER = aVO_VisionIdol_RoomLook.Play();
	Display(T("RM.VISION.IDOL.ROOM.LOOK"));
  VOICEOVER.Stop();
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Vision Door
int _visionDoorX = 219;
int _visionDoorY = 97;
function oVisionDoor_Interact(Object *theObject, CursorMode mode)
{
	if (_idol_interation != 0){
		WalkToInteraction(_visionDoorX, _visionDoorY, eDirectionUp, WAIT_DEFAULT);
		VOICEOVER = aVO_VisionIdol_DoorInteract.Play();
		Display(T("RM.VISION.IDOL.DOOR.INTERACT"));
		VOICEOVER.Stop();
	}
}

function oVisionDoor_Look(Object *theObject, CursorMode mode)
{
	if (_idol_interation == 0){
		VOICEOVER = aVO_VisionIdol_DoorLook_1.Play();
		Display(T("RM.VISION.IDOL.DOOR.LOOK.1"));
		VOICEOVER.Stop();
	} else {
		VOICEOVER = aVO_VisionIdol_DoorLook_2.Play();
		Display(T("RM.VISION.IDOL.DOOR.LOOK.2"));
		VOICEOVER.Stop();
	}
}

function oVisionDoor_UseInv(Object *theObject, CursorMode mode)
{
	if (_idol_interation != 0){
		WalkToInteraction(_visionDoorX, _visionDoorY, eDirectionUp, WAIT_DEFAULT);
		if (player.ActiveInventory == iInvLitTorch){
	    oVisionDoor.Animate(0, 5, eOnce, eBlock, eForwards);
	    oVisionDoor.Visible = false;
	    Wait(WAIT_DEFAULT);
	    VOICEOVER = aVO_VisionIdol_DoorUseInvTorchLit.Play();
			Display(T("RM.VISION.IDOL.DOOR.USEINV.TORCH.LIT"));
			VOICEOVER.Stop();

	    //Walk to location behind door
			cEgo.Walk(287, 82, eBlock, eAnywhere);
		}
	}
}



// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

// Tinderbox
function oTinderbox_Look(Object *theObject, CursorMode mode)
{
	VOICEOVER = aVO_VisionIdol_TinderboxLook.Play();
	Display(T("RM.VISION.IDOL.TINDERBOX.LOOK"));
	VOICEOVER.Stop();
}

function oTinderbox_Interact(Object *theObject, CursorMode mode)
{
	WalkToInteraction(243, 112, eDirectionUp, WAIT_DEFAULT);
	
	// Change View to PickUpGround
  player.ChangeView(HERO_PICKUPGROUND);
  Wait(20);

	oTinderbox.Visible = false;
	VOICEOVER = aVO_VisionIdol_TinderboxInteract.Play();
	Display(T("RM.VISION.IDOL.TINDERBOX.INTERACT"));
	VOICEOVER.Stop();
	player.AddInventory(iInvTinderbox);

	// Change View to Walk
  player.ChangeView(HERO_WALK);
}

