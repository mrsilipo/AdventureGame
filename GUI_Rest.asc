// ==============================
// GUI_Rest.asc (module script)
// ==============================

void CloseRestGUI(){
    guiRest.Visible = false;
    CursorReturnPrevious();
}

void btnRest1Hour_OnClick(GUIControl *control, MouseButton button)
{
  Time_AdvanceHours(1);
  CloseRestGUI();
}

function btnRestUntilNight_OnClick(GUIControl *control, MouseButton button)
{
  Time_AdvanceUntilDusk();
  CloseRestGUI();
}

void btnRestUntilMorning_OnClick(GUIControl *control, MouseButton button)
{
  Time_AdvanceUntilMorning();
  CloseRestGUI();
}

void btnRestCancel_OnClick(GUIControl *control, MouseButton button)
{
  CloseRestGUI();
}


