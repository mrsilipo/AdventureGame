// ==========================================
// SpellDataBase.asc (SCRIPT)
// ==========================================

SpellTemplate _spell_db[SPELL_COUNT];

int SpellDB_ClampSkill(int skill_value){
  if (skill_value < 0) return 0;
  if (skill_value > SPELL_SKILL_MAX_CAP) return SPELL_SKILL_MAX_CAP;
  return skill_value;
}

void SpellDB_ResetSpell(SpellId spell_id){
  int i = 0;

  _spell_db[spell_id].name = "";
  _spell_db[spell_id].desc = "";
  _spell_db[spell_id].usable_in_battle = false;
  _spell_db[spell_id].adventure_fx = -1;

  while (i < SPELL_SKILL_LEVEL_COUNT){
    _spell_db[spell_id].mp_cost[i] = 0;
    _spell_db[spell_id].power[i] = 0;
    _spell_db[spell_id].battle_fx[i] = -1;

    _spell_db[spell_id].mp_cost[i] = 0;
    _spell_db[spell_id].power[i] = 0;
    i++;
  }
}

void SpellDB_SetBattleData(SpellId spell_id, int lvl0_mp, int lvl1_mp, int lvl2_mp, int lvl0_power, int lvl1_power, int lvl2_power, int lvl0_fx, int lvl1_fx, int lvl2_fx){
  _spell_db[spell_id].mp_cost[0] = lvl0_mp;
  _spell_db[spell_id].mp_cost[1] = lvl1_mp;
  _spell_db[spell_id].mp_cost[2] = lvl2_mp;

  _spell_db[spell_id].power[0] = lvl0_power;
  _spell_db[spell_id].power[1] = lvl1_power;
  _spell_db[spell_id].power[2] = lvl2_power;

  _spell_db[spell_id].battle_fx[0] = lvl0_fx;
  _spell_db[spell_id].battle_fx[1] = lvl1_fx;
  _spell_db[spell_id].battle_fx[2] = lvl2_fx;
}

void SpellDB_SetAdventureData(SpellId spell_id, int lvl0_mp, int lvl1_mp, int lvl2_mp, int lvl0_power, int lvl1_power, int lvl2_power, int fx){
  _spell_db[spell_id].mp_cost[0] = lvl0_mp;
  _spell_db[spell_id].mp_cost[1] = lvl1_mp;
  _spell_db[spell_id].mp_cost[2] = lvl2_mp;

  _spell_db[spell_id].power[0] = lvl0_power;
  _spell_db[spell_id].power[1] = lvl1_power;
  _spell_db[spell_id].power[2] = lvl2_power;

  _spell_db[spell_id].adventure_fx = fx;
}

// ====================================================================================
// Spell DataBase
// ====================================================================================

// Add spells here:

void SpellDB_Init(){
  int i = 0;
  while (i < SPELL_COUNT){
    SpellDB_ResetSpell(i);
    i++;
  }

  // Data structure:
  // MP             1 2 3
  // Effect         1 2 3
  // Battle View    1 2 3
  // Adventure View 1

  // Vindor
  _spell_db[eSpellVindor].name = T("SPELL.VINDOR.NAME");
  _spell_db[eSpellVindor].desc = T("SPELL.VINDOR.DESC");
  _spell_db[eSpellVindor].usable_in_battle = true;
  SpellDB_SetBattleData(eSpellVindor,
                        2, 3, 4,
                        8, 12, 16,
                        0, 1, 2);

  // Ploom
  _spell_db[eSpellPloom].name = T("SPELL.PLOOM.NAME");
  _spell_db[eSpellPloom].desc = T("SPELL.PLOOM.DESC");
  _spell_db[eSpellPloom].usable_in_battle = true;
  SpellDB_SetBattleData(eSpellPloom,
                        4, 5, 6,
                        14, 20, 28,
                        10, 11, 12);
  SpellDB_SetAdventureData(eSpellPloom,
                        2, 2, 3,
                        1, 2, 3,
                        20);

   // Rah
  _spell_db[eSpellRah].name = T("SPELL.RAH.NAME");
  _spell_db[eSpellRah].desc = T("SPELL.RAH.DESC");
  _spell_db[eSpellRah].usable_in_battle = true;
  SpellDB_SetBattleData(eSpellRah,
                        4, 5, 6,
                        14, 20, 28,
                        10, 11, 12);
  SpellDB_SetAdventureData(eSpellRah,
                        2, 2, 3,
                        1, 2, 3,
                        20);

  // Hum
  _spell_db[eSpellHum].name = T("SPELL.HUM.NAME");
  _spell_db[eSpellHum].desc = T("SPELL.HUM.DESC");
  _spell_db[eSpellHum].usable_in_battle = true;
  SpellDB_SetBattleData(eSpellHum,
                        4, 5, 6,
                        14, 20, 28,
                        10, 11, 12);
  SpellDB_SetAdventureData(eSpellHum,
                        2, 2, 3,
                        1, 2, 3,
                        20);
}

// ====================================================================================

int SpellDB_ScaleBattlePowerFromSkill(int base_power, int skill_value){
  int skill = SpellDB_ClampSkill(skill_value);
  int scaled = base_power + ((base_power * skill) / 100);
  if (scaled < 1){
    scaled = 1;
  }
  return scaled;
}

int SpellDB_GetMaxSkillCap(){
  return SPELL_SKILL_MAX_CAP;
}

int SpellDB_GetSkillLevelFromSkillValue(int skill_value){
  int skill = SpellDB_ClampSkill(skill_value);

  if (skill >= SPELL_SKILL_THRESHOLD_3) return 2;
  if (skill >= SPELL_SKILL_THRESHOLD_2) return 1;
  return 0;
}

String SpellDB_GetName(SpellId spell_id){
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return "Unknown";
  return _spell_db[spell_id].name;
}

bool SpellDB_IsUsable(SpellId spell_id, bool is_battle_context){
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return false;

  if (is_battle_context){
    return _spell_db[spell_id].usable_in_battle;
  }

  return true;
}

int SpellDB_GetMPCost(SpellId spell_id, bool is_battle_context, int skill_value){
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return 0;
  int lvl = SpellDB_GetSkillLevelFromSkillValue(skill_value);

  return _spell_db[spell_id].mp_cost[lvl];
}

int SpellDB_GetPower(SpellId spell_id, bool is_battle_context, int skill_value){
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return 0;
  int lvl = SpellDB_GetSkillLevelFromSkillValue(skill_value);

  return _spell_db[spell_id].power[lvl];
}

int SpellDB_GetFX(SpellId spell_id, bool is_battle_context, int skill_value){
  if (spell_id < 0 || spell_id >= SPELL_COUNT) return -1;
  int lvl = SpellDB_GetSkillLevelFromSkillValue(skill_value);

  if (is_battle_context){
    return _spell_db[spell_id].battle_fx[lvl];
  }

  return _spell_db[spell_id].adventure_fx;
}