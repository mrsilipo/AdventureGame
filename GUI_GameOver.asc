// ==========================================
// GUI_GameOver.asc (SCRIPT)
// ==========================================

void GameOverData(String identifier){
  switch(identifier){
    case "toad":
      lblGameOverTitle.Text = T("DEATH.TOAD.TITLE");
      lblGameOverText.Text = T("DEATH.TOAD.TEXT");
      //btnGameOver_Graphic.NormalGraphic = 131;
      break;
    default: break;
  }
}

void GameOverGui_Open(String identifier){
	// Hide gameplay UI
  gStatusline.Visible = false;
  gIconbar.Visible = false;
  
	// Force Cursor Mode
	CursorDisableMouseModes();
  CursorForcePointerMode();

  // Show the GUI
	guiGameOver.Visible = true;

	// Update GUI Content
	GameOverData(identifier);

  // Game Over Music
  Music_Play(aGameOver, false);
}

void GameOverGui_EnableButtons(bool enabled){
  btnGameOver_Restart.Enabled = enabled;
  btnGameOver_Restore.Enabled = enabled;
  btnGameOver_Quit.Enabled = enabled;
}

void btnGameOver_Restore_OnClick(GUIControl *control, MouseButton button){
  guiGameOver.ZOrder = 0;
  gRestoreGame.ZOrder = 1;
  GameOverGui_EnableButtons(false);
	lstRestoreGamesList.FillSaveGameList();
	gRestoreGame.Visible = true;
}

void btnGameOver_Restart_OnClick(GUIControl *control, MouseButton button){
  RestartGame();
}

void btn_GameOver_Quit_OnClick(GUIControl *control, MouseButton button)
{
  guiGameOver.ZOrder = 0;
  gExitGame.ZOrder = 1;
  GameOverGui_EnableButtons(false);
  gExitGame.Visible = true;
}
